<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ForgotPasswordController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="header-bar">
         <children>
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 24px;">
               <HBox.margin>
                  <Insets right="10.0" />
               </HBox.margin>
            </Label>
            <Label text="BLOODLINK" styleClass="logo-text" />
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <!-- Center Card -->
      <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
         <children>
            <VBox maxWidth="550.0" prefWidth="500.0" spacing="25.0" styleClass="glass-card">
               <children>
                  <!-- Title -->
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="🛡" style="-fx-font-size: 36px; -fx-text-fill: -primary;" />
                        <Label styleClass="title-text" text="Mot de passe oublié" />
                        <Label styleClass="subtitle-text" text="Saisissez votre e-mail et nous vous enverrons un lien de réinitialisation." />
                     </children>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </VBox>

                  <!-- Error/Success Label -->
                  <Label fx:id="statusLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-font-weight: bold; -fx-font-size: 13px;" text="" visible="false" managed="false" />

                  <!-- Main Flow (VBox swapped out conditionally) -->
                  <VBox fx:id="requestContainer" spacing="20.0">
                      <!-- Email -->
                      <VBox spacing="8.0">
                         <children>
                            <Label styleClass="form-label" text="ADRESSE E-MAIL" />
                            <TextField fx:id="emailF" maxWidth="1.7976931348623157E308" promptText="nom@exemple.com" styleClass="text-field-custom" />
                         </children>
                      </VBox>
                      
                      <!-- reCAPTCHA Container -->
                      <VBox alignment="CENTER">
                         <WebView fx:id="recaptchaWebView" prefHeight="80.0" prefWidth="304.0" maxWidth="304.0" minHeight="80.0" />
                      </VBox>
                      
                      <!-- Action Buttons -->
                      <Button fx:id="sendBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSendLink" styleClass="button-primary" text="✉ Envoyer le lien" />
                  </VBox>
                  
                  <!-- Token Input Flow -->
                  <VBox fx:id="tokenContainer" spacing="20.0" visible="false" managed="false">
                      <Label text="Un lien et un code de réinitialisation ont été envoyés à votre adresse e-mail." style="-fx-text-fill: #4caf50; -fx-alignment: center;" wrapText="true" />
                      <!-- Token -->
                      <VBox spacing="8.0">
                         <children>
                            <Label styleClass="form-label" text="CODE DE RÉINITIALISATION" />
                            <TextField fx:id="tokenF" maxWidth="1.7976931348623157E308" promptText="Collez votre code ici" styleClass="text-field-custom" />
                         </children>
                      </VBox>
                      <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleVerifyToken" styleClass="button-primary" text="Vérifier le code" />
                  </VBox>
                  
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleBackToLogin" styleClass="button-link" text="← Retour à la connexion" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
