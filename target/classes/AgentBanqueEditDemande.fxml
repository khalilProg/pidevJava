<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueEditDemandeController" spacing="30"
      style="-fx-background-color: #0d0d0d; -fx-padding: 40 50;">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Region HBox.hgrow="ALWAYS" />
        <Button text="← Retour" style="-fx-text-fill: white; -fx-background-color: #1a1a1a; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-padding: 8 20;" onAction="#goBack"/>
    </HBox>

    <VBox spacing="5">
        <Label text="BLOODLINK" styleClass="page-subtitle" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <SVGPath content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="#E53935" scaleX="1.3" scaleY="1.3"/>
            <Label fx:id="lblTitle" text="Modifier Demande #25" styleClass="page-title"/>
        </HBox>
        <Label text="Modifier les détails de votre demande." styleClass="page-subtitle"/>
    </VBox>

    <VBox spacing="25" style="-fx-background-color: #111111; -fx-border-color: #222222; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 40 50;" VBox.vgrow="ALWAYS">
        
        <VBox spacing="20">
            <VBox spacing="4">
                <Label text="Banque" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                <ComboBox fx:id="comboBanque" promptText="Sélectionnez une banque" styleClass="dark-combo-box" maxWidth="Infinity" prefHeight="45"/>
                <Label fx:id="errBanque" text="Ce champ est requis" style="-fx-text-fill: #E53935; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>
            
            <VBox spacing="4">
                <Label text="Type de sang" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                <ComboBox fx:id="comboType" promptText="Choisissez un type" styleClass="dark-combo-box" maxWidth="Infinity" prefHeight="45"/>
                <Label fx:id="errType" text="Ce champ est requis" style="-fx-text-fill: #E53935; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Quantité (unités)" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                <TextField fx:id="txtQuantite" promptText="10" styleClass="search-field" prefHeight="45"/>
                <Label fx:id="errQuantite" text="Ce champ est requis" style="-fx-text-fill: #E53935; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Urgence" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                <ComboBox fx:id="comboUrgence" promptText="Sélectionnez" styleClass="dark-combo-box" maxWidth="Infinity" prefHeight="45"/>
                <Label fx:id="errUrgence" text="Ce champ est requis" style="-fx-text-fill: #E53935; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>
        </VBox>
        
        <Region VBox.vgrow="ALWAYS" />

        <HBox spacing="15">
            <Button text="💾 Enregistrer les modifications" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 15;" onAction="#handleUpdate"/>
            <Button text="Annuler" style="-fx-background-color: #050505; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #222222; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 15 40;" onAction="#goBack"/>
        </HBox>
    </VBox>
</VBox>
