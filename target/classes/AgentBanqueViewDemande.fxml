<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueViewDemandeController" spacing="25"
      style="-fx-background-color: #0d0d0d; -fx-padding: 40 50;">

    <Button text="← Retour aux demandes" style="-fx-text-fill: #b3b3b3; -fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" onAction="#goBack"/>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" styleClass="page-subtitle" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            <Label fx:id="lblTitle" text="Demande #25" styleClass="page-title"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                <Label fx:id="lblCreatedAt" text="Créée le 22 Apr 2026 à 18:44" styleClass="page-subtitle"/>
            </HBox>
        </VBox>
        
        <Label fx:id="lblStatusTop" text="● En Attente de Validation" style="-fx-background-color: rgba(255, 193, 7, 0.1); -fx-text-fill: #ffc107; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 20;"/>
    </HBox>

    <VBox spacing="25" style="-fx-background-color: #111111; -fx-border-color: #222222; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 40 50;" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-border-color: #222222; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
            <StackPane style="-fx-background-color: #1a0a0a; -fx-background-radius: 10; -fx-padding: 10;">
                <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z" fill="#E53935"/>
            </StackPane>
            <VBox>
                <Label text="INFORMATIONS DÉTAILLÉES" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                <Label text="Récapitulatif des besoins en produits sanguins." style="-fx-text-fill: #555555; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <FlowPane hgap="20" vgap="20">
            <!-- Card 1 -->
            <VBox spacing="10" prefWidth="250" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="TYPE DE SANG" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblType" text="A+" style="-fx-text-fill: #E53935; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </VBox>
            
            <!-- Card 2 -->
            <VBox spacing="10" prefWidth="250" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="QUANTITÉ" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="5" alignment="BASELINE_LEFT">
                    <Label fx:id="lblQuantite" text="10" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="unités" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

            <!-- Card 3 -->
            <VBox spacing="10" prefWidth="250" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="URGENCE" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblUrgence" text="Normale" style="-fx-background-color: #222222; -fx-text-fill: white; -fx-padding: 4 12; -fx-background-radius: 12; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Card 4 -->
            <VBox spacing="10" prefWidth="300" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="BANQUE CIBLE" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblBanque" text="Mahmoud El Matri Hospital" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>
        </FlowPane>
        
        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 30 0 0 0;">
            <Button text="✎ Modifier" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-padding: 10 25; -fx-border-color: #333333; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;" onAction="#handleEdit"/>
            <Button text="🗑 Supprimer" style="-fx-background-color: #2a1111; -fx-text-fill: #ff5252; -fx-padding: 10 25; -fx-border-color: #442222; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;" onAction="#handleDelete"/>
        </HBox>
    </VBox>
</VBox>
