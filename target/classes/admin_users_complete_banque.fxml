<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@commande.css" prefHeight="900.0" prefWidth="1400.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AdminUsersCompleteBanqueController">
   <!-- Sidebar -->
   <left><fx:include source="admin_sidebar.fxml" /></left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="COMPLÉTER PROFIL" />
                <Label fx:id="subtitleLabel" style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Détails de l'établissement pour le compte." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
         </HBox>
         
         <VBox styleClass="glass-card" spacing="25.0" maxWidth="800.0" alignment="CENTER_LEFT">
             <HBox spacing="10.0" alignment="CENTER_LEFT">
                 <Label style="-fx-text-fill: -primary; -fx-font-size: 20px;" text="🏥" />
                 <VBox>
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 18px;" text="BANQUE DE SANG" />
                     <Label style="-fx-text-fill: -muted; -fx-font-size: 12px;" text="Configuration des coordonnées de l'établissement." />
                 </VBox>
             </HBox>
             
             <!-- Row 1: Nom de la banque -->
             <VBox spacing="3.0">
                 <Label styleClass="form-label" text="NOM DE LA BANQUE" />
                 <TextField fx:id="nomBanqueF" promptText="Entrez le nom de l'établissement" styleClass="text-field-custom" />
                 <Label fx:id="nomBanqueError" styleClass="field-error" text="" visible="false" managed="false" />
             </VBox>
             
             <!-- Row 2: Adresse & Téléphone -->
             <HBox spacing="20.0">
                 <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="form-label" text="ADRESSE" />
                     <TextField fx:id="adresseF" promptText="Entrez l'adresse complète" styleClass="text-field-custom" />
                     <Label fx:id="adresseError" styleClass="field-error" text="" visible="false" managed="false" />
                 </VBox>
                 <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="form-label" text="TÉLÉPHONE" />
                     <TextField fx:id="telephoneF" promptText="12345678" styleClass="text-field-custom" />
                     <Label fx:id="telephoneError" styleClass="field-error" text="" visible="false" managed="false" />
                 </VBox>
             </HBox>
             
             <HBox alignment="CENTER_RIGHT">
                 <Button mnemonicParsing="false" onAction="#handleConfirm" styleClass="button-primary" text="CONFIRMER ✓" />
             </HBox>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>
