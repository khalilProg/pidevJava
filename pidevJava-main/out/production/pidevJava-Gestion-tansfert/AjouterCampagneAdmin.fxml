<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@commande.css" styleClass="main-container" prefHeight="900.0" prefWidth="1400.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AjouterCampagneAdmin">
   <!-- Sidebar -->
   <left><fx:include fx:id="sidebar" source="admin_sidebar.fxml" /></left>

   <center>
      <VBox styleClass="main-content" spacing="35.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="80.0" right="80.0" top="40.0" />
         </padding>

         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="Nouvelle Campagne" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Interface d'administration" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="retour-button" mnemonicParsing="false" text="← Retour à la liste" onAction="#handleRetour" />
         </HBox>

         <VBox styleClass="glass-card" spacing="25.0" VBox.vgrow="ALWAYS">
            
            <VBox spacing="5.0">
               <Label text="Titre de la campagne" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <TextField styleClass="dark-field" fx:id="titreInput" />
               <Label fx:id="titreError" text="Donnez un titre accrocheur à votre campagne." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <VBox spacing="5.0">
               <Label text="Description" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <TextArea styleClass="dark-field" fx:id="descInput" prefRowCount="3" />
               <Label fx:id="descError" text="Décrivez les objectifs et les détails de la campagne." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <HBox spacing="20.0">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Date de début" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <DatePicker styleClass="dark-field" fx:id="dateDebutInput" promptText="mm / dd / yyyy" maxWidth="1.7976931348623157E308"/>
                    <Label fx:id="dateDebutError" text="Quand commence la campagne ?" style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Date de fin" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <DatePicker styleClass="dark-field" fx:id="dateFinInput" promptText="mm / dd / yyyy" maxWidth="1.7976931348623157E308"/>
                    <Label fx:id="dateFinError" text="Quand se termine la campagne ?" style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                </VBox>
            </HBox>

            <VBox spacing="5.0">
               <Label text="Type(s) de sang" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <FlowPane hgap="10" vgap="10" style="-fx-padding: 15px; -fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;">
                    <ToggleButton fx:id="tglAplus" text="A+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglAminus" text="A-" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglBplus" text="B+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglBminus" text="B-" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglABplus" text="AB+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglABminus" text="AB-" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglOplus" text="O+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglOminus" text="O-" styleClass="toggle-blood-type" />
               </FlowPane>
               <Label fx:id="typesError" text="Sélectionnez les groupes sanguins ciblés." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <VBox spacing="5.0">
               <Label text="Lieu(x) de Collecte Associé(s)" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <FlowPane fx:id="entitesFlowPane" hgap="10" vgap="10" style="-fx-padding: 15px; -fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;">
                    <!-- Dynamically populated from Java Controller -->
               </FlowPane>
               <Label fx:id="entitesError" text="Sélectionnez une ou plusieurs entités pour la campagne." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button mnemonicParsing="false" text="Créer la campagne" onAction="#handleCreer" styleClass="button-primary" maxWidth="1.7976931348623157E308"/>
            
         </VBox>
      </VBox>
   </center>
</BorderPane>
