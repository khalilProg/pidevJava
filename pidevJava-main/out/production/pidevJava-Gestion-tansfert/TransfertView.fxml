<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.TransfertController"
            stylesheets="@commande.css">

    <children>

        <VBox spacing="15" layoutX="20" layoutY="20" prefWidth="900" styleClass="form-card">

            <Label text="Gestion des Transferts" styleClass="label-title"/>

            <TableView fx:id="tableTransfert" prefHeight="400">

                <columns>

                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colDemande" text="Demande"/>
                    <TableColumn fx:id="colFrom" text="From"/>
                    <TableColumn fx:id="colTo" text="To"/>
                    <TableColumn fx:id="colQuantite" text="Quantité"/>
                    <TableColumn fx:id="colStock" text="Stock"/>
                    <TableColumn fx:id="colDateEnvoie" text="Date Envoi"/>
                    <TableColumn fx:id="colDateReception" text="Date Réception"/>
                    <TableColumn fx:id="colStatus" text="Status"/>
                    <TableColumn fx:id="colActions" text="Actions"/>

                </columns>

            </TableView>

            <HBox spacing="10">
                <Button text="Ajouter" onAction="#openForm" styleClass="btn-primary"/>
                <Button text="Retour" onAction="#retour" styleClass="btn-secondary"/>
            </HBox>

        </VBox>

    </children>
</AnchorPane>
