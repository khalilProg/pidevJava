<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@commande.css" prefHeight="900.0" prefWidth="1400.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.backTransfertController">
   <!-- Sidebar -->
   <left><fx:include source="admin_sidebar.fxml" /></left>

   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT">
             <VBox spacing="5.0">
                 <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="TRANSFERTS DE SANG" />
                 <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Suivez les transferts entre organisations et leur statut." />
             </VBox>
             <Region HBox.hgrow="ALWAYS" />
         </HBox>

         <VBox styleClass="glass-card" spacing="20.0" VBox.vgrow="ALWAYS">
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="text-field-custom" prefWidth="400.0">
                    <Label text="🔍" style="-fx-text-fill: -muted;" />
                    <TextField promptText="Rechercher par destination, statut..." styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button styleClass="filter-btn" mnemonicParsing="false" text="Tous statuts" />
            </HBox>

            <TableView fx:id="tableTransfert" VBox.vgrow="ALWAYS" >
               <columns>
                  <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                  <TableColumn fx:id="colDemande" text="DEMANDE" prefWidth="120"/>
                  <TableColumn fx:id="colFrom" text="ORIGINE" prefWidth="180"/>
                  <TableColumn fx:id="colTo" text="DESTINATION" prefWidth="180"/>
                  <TableColumn fx:id="colQuantite" text="QUANTITÉ" prefWidth="100"/>
                  <TableColumn fx:id="colDateEnvoie" text="DATE ENVOI" prefWidth="120"/>
                  <TableColumn fx:id="colStatus" text="STATUT" prefWidth="120"/>
                  <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="200"/>
               </columns>
            </TableView>
         </VBox>

      </VBox>
   </center>
</BorderPane>
