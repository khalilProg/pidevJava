<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.FrontMedicalController">
    <stylesheets><URL value="@front.css" /></stylesheets>

    <VBox styleClass="hero-section">

        <HBox alignment="CENTER" styleClass="navbar-top">
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brand-section">
                <Circle fill="#e63939" radius="8.0" />
                <Label styleClass="brand-text" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="20.0" styleClass="nav-links-container">
                <Label styleClass="nav-link-active" text="Health Passport" />
                <Button onAction="#goToMyDonations" styleClass="nav-link" text="Donation Legacy" />
                <HBox alignment="CENTER" styleClass="user-pill">
                    <Circle fill="#e63939" radius="10.0" />
                    <Label fx:id="nameLabel" styleClass="user-name-label" text="Loading..." />
                </HBox>
                <Button styleClass="menu-button" text="SYSTEM ☰" />
            </HBox>
        </HBox>

        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox alignment="CENTER" spacing="40.0">
                <padding><Insets bottom="60.0" left="60.0" right="60.0" top="40.0" /></padding>

                <VBox spacing="10">
                    <Label styleClass="hero-title-large" text="Biometric Profile." />
                    <Label styleClass="hero-description-v2" text="Systemized vitals recording and integrated Machine Learning modeling." />
                </VBox>

                <HBox spacing="35.0" VBox.vgrow="ALWAYS">
                    <!-- Bio-Data Box (LEFT) -->
                    <VBox prefWidth="450.0" minWidth="450.0" spacing="25.0" styleClass="card" style="-fx-background-color: #121212;">
                        <Label styleClass="stat-card-subtitle" text="LATEST SYNCHRONIZATION" />
                        <GridPane hgap="30" vgap="30">
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"><Label styleClass="form-label" text="BLOOD CLASS"/><Label fx:id="bloodLabel" styleClass="card-title"/></VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"><Label styleClass="form-label" text="BIO-AGE"/><Label fx:id="ageLabel" styleClass="card-title"/></VBox>
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1"><Label styleClass="form-label" text="ELEVATION"/><Label fx:id="heightLabel" styleClass="card-title"/></VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"><Label styleClass="form-label" text="CORE MASS"/><Label fx:id="weightLabel" styleClass="card-title"/></VBox>
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2"><Label styleClass="form-label" text="CHROMOSOME RECORD"/><Label fx:id="genderLabel" styleClass="card-title"/></VBox>
                        </GridPane>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button onAction="#handleUpdateProfile" styleClass="btn-secondary-home" text="FORCE OVERRIDE BIOMETRICS" maxWidth="Infinity" />
                    </VBox>

                    <!-- Advanced ML, Charts & Gauges (RIGHT) -->
                    <VBox spacing="30.0" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-background-color: #121212; -fx-padding: 30 40;">
                        <HBox alignment="CENTER" spacing="40" VBox.vgrow="ALWAYS">
                            <!-- Gauge -->
                            <VBox alignment="CENTER" spacing="20">
                                <Label styleClass="stat-card-subtitle" text="VITASPHERE INDEX" />
                                <StackPane>
                                    <ImageView fx:id="bmiQuickChartImage" fitHeight="200" fitWidth="260" preserveRatio="true"/>
                                    <Label fx:id="bmiValueLabel" style="-fx-font-size: 35; -fx-font-weight: 900; -fx-text-fill: white;" translateY="45"/>
                                </StackPane>
                                <Label fx:id="bmiStatusLabel" style="-fx-font-weight: 900; -fx-padding: 6 16; -fx-background-radius: 5;" text="EVALUATING" />

                                <!-- Standalone AI Simulation Button (Completely divorced from KNN) -->
                                <Region VBox.vgrow="ALWAYS" />
                                <Button onAction="#runDeepAIScan" styleClass="btn-prime-home" text="AI SYNTHESIS" />
                            </VBox>

                            <!-- Trajectory Graph & DEDICATED KNN WIDGET -->
                            <VBox spacing="20" HBox.hgrow="ALWAYS">
                                <!-- Line Chart -->
                                <VBox spacing="5" VBox.vgrow="ALWAYS">
                                    <Label styleClass="stat-card-subtitle" text="MASS TRAJECTORY" />
                                    <LineChart fx:id="biometricChart" legendVisible="false" style="-fx-background-color: transparent; -fx-padding: -10 0 0 0;" minHeight="180">
                                        <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="#999" /></xAxis>
                                        <yAxis><NumberAxis side="LEFT" forceZeroInRange="false" tickLabelFill="#999"/></yAxis>
                                    </LineChart>
                                </VBox>

                                <!-- == NEW: DEDICATED MACHINE LEARNING KNN WIDGET == -->
                                <VBox styleClass="glass-card" style="-fx-border-color: #4a90e2; -fx-border-width: 1 1 1 5; -fx-background-color: rgba(20,25,35,0.7); -fx-padding: 15;">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Circle radius="4" fill="#4a90e2" />
                                        <Label styleClass="form-label" style="-fx-text-fill: #4a90e2;" text="KNN EUCLIDEAN DISTANCE MACHINE LEARNING" />
                                    </HBox>
                                    <Label fx:id="knnResultLabel" text="Initializing Dataset Clustering Model..." style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 8 0 4 0;" wrapText="true" />
                                    <Label text="Optimal extracted donation path generated based on mathematically similar physical profiles." styleClass="form-label" style="-fx-font-size: 11;" wrapText="true" />
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- FULLSCREEN AI OVERLAY (Separated strictly from ML logic!) -->
    <StackPane fx:id="aiOverlay" mouseTransparent="true" visible="false" style="-fx-background-color: rgba(10,10,10,0.92);">
        <VBox maxWidth="800" maxHeight="500" spacing="30" alignment="CENTER" styleClass="glass-card" style="-fx-border-color: #cc2be2; -fx-border-width: 2;">
            <padding><Insets bottom="60" left="60" right="60" top="60" /></padding>
            <HBox alignment="CENTER" spacing="15">
                <Circle radius="6" fill="#cc2be2"/>
                <Label styleClass="hero-title-large" style="-fx-font-size: 26;" text="GENERATIVE HEALTH INSIGHTS" />
            </HBox>
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <Label fx:id="overlayAiText" wrapText="true" style="-fx-text-fill: #e0e0e0; -fx-font-size: 18px; -fx-line-spacing: 8px;" />
            </ScrollPane>
            <Button onAction="#closeAIOverlay" text="END AI INSTANCE" styleClass="btn-primary-modern" />
        </VBox>
    </StackPane>

</StackPane>