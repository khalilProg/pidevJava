<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="900.0" prefWidth="1400.0" styleClass="front-flow-root"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.AjouterQuestionnaire">
   <stylesheets>
      <URL value="@commande.css" />
      <URL value="@styleFront.css" />
   </stylesheets>
   <children>
      <BorderPane styleClass="front-flow-root">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" styleClass="nav-bar">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="6">
                     <Label styleClass="brand-label" text="BLOODLINK" />
                  </HBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleThemeToggle" styleClass="theme-toggle-btn" text="Light" />
                  <Region prefWidth="12.0" />
                  <Button fx:id="userNameBtn" mnemonicParsing="false" styleClass="user-badge" text="Utilisateur" />
                  <Region prefWidth="12.0" />
                  <Button fx:id="menuToggleBtn" mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="menu-toggle" text="MENU" />
               </children>
            </HBox>
         </top>

         <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="front-flow-scroll">
               <content>
                  <VBox alignment="TOP_CENTER" spacing="28.0" styleClass="front-flow-page">
                     <padding>
                        <Insets bottom="50.0" left="50.0" right="50.0" top="44.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="1040.0" spacing="28.0" styleClass="front-flow-hero">
                           <children>
                              <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="flow-eyebrow" text="Étape 1 sur 2" />
                                    <Label styleClass="flow-title" text="Remplir le questionnaire" />
                                    <Label maxWidth="650.0" styleClass="flow-subtitle" text="Complétez ces informations pour vérifier votre éligibilité avant de choisir un rendez-vous." wrapText="true" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER_LEFT" minWidth="230.0" spacing="6.0" styleClass="flow-progress-card">
                                 <children>
                                    <Label styleClass="flow-progress-kicker" text="DON DE SANG" />
                                    <Label styleClass="flow-progress-title" text="Questionnaire médical" />
                                    <Label styleClass="flow-progress-copy" text="3 champs requis" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <HBox alignment="TOP_CENTER" maxWidth="1040.0" spacing="28.0">
                           <children>
                              <VBox minWidth="310.0" prefWidth="330.0" spacing="18.0" styleClass="flow-info-panel">
                                 <children>
                                    <Label styleClass="flow-panel-label" text="Votre parcours" />
                                    <VBox spacing="14.0">
                                       <children>
                                          <HBox alignment="CENTER_LEFT" spacing="12.0">
                                             <children>
                                                <Label styleClass="flow-step-dot-active" text="1" />
                                                <VBox spacing="2.0">
                                                   <children>
                                                      <Label styleClass="flow-step-title" text="Questionnaire" />
                                                      <Label styleClass="flow-step-copy" text="Informations donneur" />
                                                   </children>
                                                </VBox>
                                             </children>
                                          </HBox>
                                          <HBox alignment="CENTER_LEFT" spacing="12.0">
                                             <children>
                                                <Label styleClass="flow-step-dot" text="2" />
                                                <VBox spacing="2.0">
                                                   <children>
                                                      <Label styleClass="flow-step-title" text="Rendez-vous" />
                                                      <Label styleClass="flow-step-copy" text="Date, heure et lieu" />
                                                   </children>
                                                </VBox>
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    <Region prefHeight="10.0" />
                                    <Label styleClass="flow-note" text="Les données saisies restent liées à votre session BloodLink et servent à préparer votre don." wrapText="true" />
                                 </children>
                              </VBox>

                              <VBox maxWidth="682.0" prefWidth="682.0" spacing="22.0" styleClass="front-form-card">
                                 <padding>
                                    <Insets bottom="30.0" left="34.0" right="34.0" top="30.0" />
                                 </padding>
                                 <children>
                                    <VBox spacing="6.0">
                                       <children>
                                          <Label styleClass="front-form-title" text="Informations donneur" />
                                          <Label styleClass="front-form-subtitle" text="Vérifiez les critères principaux avant de continuer." />
                                       </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                       <children>
                                          <Label styleClass="front-form-label" text="Âge" />
                                          <TextField fx:id="age" maxWidth="1.7976931348623157E308" promptText="Entrez votre âge" styleClass="front-input" />
                                          <Text fx:id="ageError" styleClass="error-text" visible="false" />
                                       </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                       <children>
                                          <Label styleClass="front-form-label" text="Sexe" />
                                          <ComboBox fx:id="sexe" maxWidth="1.7976931348623157E308" promptText="Sélectionnez votre sexe" styleClass="front-combo">
                                             <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                   <String fx:value="Homme" />
                                                   <String fx:value="Femme" />
                                                </FXCollections>
                                             </items>
                                          </ComboBox>
                                          <Text fx:id="sexeError" styleClass="error-text" visible="false" />
                                       </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                       <children>
                                          <Label styleClass="front-form-label" text="Poids (kg)" />
                                          <TextField fx:id="poids" maxWidth="1.7976931348623157E308" promptText="Ex: 70" styleClass="front-input" />
                                          <Text fx:id="poidsError" styleClass="error-text" visible="false" />
                                       </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                       <children>
                                          <Label styleClass="front-form-label" text="Autres informations" />
                                          <TextArea fx:id="autres" maxWidth="1.7976931348623157E308" prefHeight="118.0" promptText="Antécédents médicaux, allergies..." styleClass="front-input" wrapText="true" />
                                       </children>
                                    </VBox>

                                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                                       <children>
                                          <Button fx:id="continuer" mnemonicParsing="false" onAction="#handleContinuer" styleClass="btn-primary-modern" text="Continuer" />
                                          <Button fx:id="annuler" mnemonicParsing="false" onAction="#handleAnnuler" styleClass="btn-outline" text="Annuler" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </center>
      </BorderPane>

      <HBox fx:id="menuOverlay" alignment="CENTER_RIGHT" managed="false" visible="false">
         <children>
            <Region onMouseClicked="#handleMenuClose" styleClass="menu-backdrop" HBox.hgrow="ALWAYS" />
            <VBox fx:id="menuPanel" alignment="TOP_LEFT" prefWidth="380.0" spacing="15.0" styleClass="menu-panel">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="submit-button" text="FERMER" />
                     </children>
                  </HBox>
                  <Region prefHeight="20.0" />
                  <Button mnemonicParsing="false" onAction="#goToAccueil" styleClass="menu-link" text="ACCUEIL" />
                  <Button mnemonicParsing="false" onAction="#goToCampagnes" styleClass="menu-link, menu-link-active" text="CAMPAGNES" />
                  <Button mnemonicParsing="false" onAction="#goToHistorique" styleClass="menu-link" text="HISTORIQUE" />
                  <Button mnemonicParsing="false" onAction="#goToCommandes" styleClass="menu-link" text="COMMANDES" />
                  <Button mnemonicParsing="false" styleClass="menu-link" text="DOSSIER MEDICAL" />
                  <Button mnemonicParsing="false" onAction="#goToProfile" styleClass="menu-link" text="MON PROFIL" />
                  <Region VBox.vgrow="ALWAYS" />
                  <VBox spacing="15.0">
                     <children>
                        <Label fx:id="sessionEmailLabel" styleClass="menu-session" text="Session: utilisateur@email.com" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="submit-button" text="DECONNEXION" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</StackPane>
