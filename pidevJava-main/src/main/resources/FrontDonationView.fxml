<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="750.0" prefWidth="1250.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.FrontDonationController">
    <stylesheets><URL value="@Front.css" /></stylesheets>

    <VBox>
        <HBox styleClass="navbar-top" alignment="CENTER">
            <HBox styleClass="brand-section">
                <Label styleClass="brand-text" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#goToMyProfile" styleClass="nav-link" text="My Profile" />
                <Button styleClass="nav-link-active" text="Donations" />
                <HBox styleClass="user-pill" alignment="CENTER">
                    <Circle radius="12" fill="#e63939" />
                    <Label styleClass="user-name-label" text="Patient Portal" />
                </HBox>
                <Button onAction="#toggleMenu" styleClass="menu-button" text="MENU ☰" />
            </HBox>
        </HBox>
        <HBox spacing="15.0" styleClass="glass-card">
            <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>

            <VBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="TOTAL GLOBAL YIELD" />
                <HBox alignment="BASELINE_LEFT" spacing="10.0">
                    <Label fx:id="totalVolumeLabel" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: 900;" text="0.0" />
                    <Label style="-fx-text-fill: #e63939; -fx-font-weight: bold;" text="mL" />
                </HBox>

                <Region VBox.vgrow="ALWAYS" />
                <Label styleClass="form-label" text="CURRENT RANKING" />
                <Label fx:id="rankLabel" style="-fx-font-size: 16px;" text="CALCULATING..." />
            </VBox>

            <VBox alignment="CENTER" spacing="5.0">
                <ImageView fx:id="qrCodeImage" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
                <Label style="-fx-text-fill: #888; -fx-font-size: 10px;" text="SCAN TO VERIFY" />
            </VBox>
        </HBox>
        <VBox styleClass="hero-section-alt">
            <Label styleClass="hero-title-large" text="Donation History" />
            <Label styleClass="hero-subtitle-alt" text="View your contributions and analyze your saving impact." />
        </VBox>

        <HBox spacing="30" VBox.vgrow="ALWAYS" styleClass="grid-container">
            <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15">
                <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                <TableView fx:id="donationTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" />
                        <TableColumn fx:id="colEntityId" text="Location" />
                        <TableColumn fx:id="colType" text="Type" />
                        <TableColumn fx:id="colQte" text="Volume" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
            </VBox>

            <VBox prefWidth="350" spacing="20">
                <VBox styleClass="glass-card" spacing="15">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                    <Label styleClass="glass-card-title" text="Impact Analysis" />
                    <Label fx:id="aiImpactLabel" styleClass="ai-text" text="Total lives saved: Calculating..." />
                    <Button onAction="#runImpactAnalysis" styleClass="btn-prime-home" text="Analyze My Heroism" maxWidth="Infinity" />
                </VBox>
            </VBox>
        </HBox>
    </VBox>

    <Region fx:id="navBackdrop" onMouseClicked="#toggleMenu" style="-fx-background-color: rgba(0,0,0,0.8);" opacity="0.0" mouseTransparent="true" />
    <VBox fx:id="navMenuPanel" prefWidth="400" styleClass="menu-panel" translateX="400" StackPane.alignment="CENTER_RIGHT">
        <Region prefHeight="100" />
        <Button onAction="#goToMyProfile" styleClass="menu-link" text="PROFILE" />
        <Button styleClass="menu-link" text="HISTORY" style="-fx-text-fill: #e63939;" />
        <Button styleClass="menu-link" text="LOGOUT" />
    </VBox>
</StackPane>