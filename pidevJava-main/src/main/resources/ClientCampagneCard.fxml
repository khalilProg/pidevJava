<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="390.0" stylesheets="@client-campagnes.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.CampagneCard">
   <children>
      <VBox spacing="18.0" styleClass="client-campaign-card" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label styleClass="card-chip" text="Collecte" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="campaignDates" styleClass="client-date" text="Du 01/05 au 10/05" />
               </children>
            </HBox>

            <VBox spacing="10.0">
               <children>
                  <Label fx:id="campaignName" styleClass="client-card-title" text="Nom de la campagne" wrapText="true" />
                  <Label fx:id="campaignDescription" styleClass="client-card-copy" text="Description de la campagne..." wrapText="true" />
               </children>
            </VBox>

            <VBox spacing="8.0" styleClass="meta-band">
               <children>
                  <Label styleClass="meta-label" text="Groupes concernes" />
                  <Label fx:id="bloodTypes" styleClass="meta-value" text="A+, O-, AB+" wrapText="true" />
               </children>
            </VBox>

            <Button fx:id="participateButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openQuestionnaire" styleClass="client-cta" text="Participer maintenant" />
         </children>
      </VBox>
   </children>
</AnchorPane>
