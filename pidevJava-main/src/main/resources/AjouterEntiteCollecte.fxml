<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@commande.css" styleClass="main-container" prefHeight="900.0" prefWidth="1400.0"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.AjouterEntiteCollecteController">
    <children>
        <VBox styleClass="main-content">
            <children>
                <!-- Header Bar -->
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" styleClass="nav-bar">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label styleClass="brand-label" text="BLOODLINK" />
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <!-- Scrollable Form Content -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <VBox styleClass="main-content" spacing="35.0">
                            <padding>
                                <Insets bottom="40.0" left="80.0" right="80.0" top="40.0" />
                            </padding>

                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="5.0">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="Nouvelle Entité" />
                                    <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Interface front-office" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button styleClass="retour-button" mnemonicParsing="false" text="← Retour" onAction="#handleRetour" />
                            </HBox>

                            <VBox styleClass="glass-card" spacing="25.0">

                                <VBox spacing="5.0">
                                    <Label text="Nom de l'entité" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                                    <TextField styleClass="dark-field" fx:id="txtNom" promptText="Ex: Hôpital Charles Nicolle" />
                                    <Label fx:id="nomError" text="Le nom officiel de l'entité de collecte (ex: Hôpital X)." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label text="Type" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                                    <TextField styleClass="dark-field" fx:id="txtType" promptText="Ex: Hôpital, Clinique, Association..." />
                                    <Label fx:id="typeError" text="Le type de l'entité." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label text="Adresse" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                                    <TextField styleClass="dark-field" fx:id="txtAdresse" promptText="Ex: 12 Rue de la République" />
                                    <Label fx:id="adresseError" text="Adresse complète de l'entité." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                                </VBox>

                                <HBox spacing="20.0">
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Ville" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                                        <TextField styleClass="dark-field" fx:id="txtVille" promptText="Ex: Tunis" />
                                        <Label fx:id="villeError" text="Ville où se situe l'entité." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                                    </VBox>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Numéro de téléphone" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                                        <TextField styleClass="dark-field" fx:id="txtTelephone" promptText="Ex: 71234567" />
                                        <Label fx:id="telephoneError" text="Exactement 8 chiffres." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                                    </VBox>
                                </HBox>

                                <Region VBox.vgrow="ALWAYS" />

                                <Button mnemonicParsing="false" text="Créer l'entité" onAction="#handleEnregistrer" styleClass="button-primary" maxWidth="1.7976931348623157E308"/>

                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</StackPane>
