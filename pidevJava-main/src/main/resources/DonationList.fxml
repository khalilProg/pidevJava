<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DonationListController">
    <stylesheets>
        <URL value="@style.css" /> <!-- Change to if you named it that -->
    </stylesheets>

    <StackPane styleClass="main-container" />

    <HBox spacing="0">
        <!-- Sidebar Navigation -->
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
            </padding>

            <VBox spacing="10.0" styleClass="sidebar-brand">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle fill="#e63939" radius="6.0" />
                    <Label styleClass="sidebar-brand-text" text="BLOODLINK" />
                </HBox>
                <Label styleClass="sidebar-admin-badge" text="INTELLIGENT SYSTEMS" />
            </VBox>

            <Region prefHeight="60.0" />

            <VBox spacing="10.0" styleClass="sidebar-nav-list">
                <Label styleClass="sidebar-section-label" text="ADMINISTRATION" />
                <Button styleClass="sidebar-nav-item" text="📊 Master Dashboard" maxWidth="Infinity" alignment="CENTER_LEFT" />

                <Button onAction="#goToMedicalFolders" styleClass="sidebar-nav-item" text="🩺 Medical Folders" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button styleClass="sidebar-nav-item-active" text="🩸 Donation Logs" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox styleClass="form-card" spacing="12">
                <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                <Label styleClass="welcome-badge-text" text="INVENTORY AI" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="4" fill="#2ecc71" />
                    <Label styleClass="admin-card-copy" text="Optimal Levels Detected" />
                </HBox>
            </VBox>
        </VBox>

        <!-- Right Core View Container -->
        <VBox styleClass="content-area" HBox.hgrow="ALWAYS" spacing="30.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label styleClass="breadcrumb-label" text="ADMIN / LOGISTICS / INVENTORY" />
                    <Label styleClass="page-title" text="Inventory Intelligence" />
                    <Label styleClass="page-subtitle" text="Tracking donation flow and supply chain stability." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="searchField" prefWidth="350" promptText="Search classification..." styleClass="dark-field" />
            </HBox>

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">

                <!-- The Logs Datagrid Area -->
                <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                    <Label styleClass="form-title" text="LIVE TRANSACTION LOGS" />
                    <TableView fx:id="donationTable" styleClass="dark-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colClientName" prefWidth="180" text="DONOR FULL NAME" />
                            <TableColumn fx:id="colEntityName" prefWidth="150" text="EXTRACTION BRANCH" />
                            <TableColumn fx:id="colType" prefWidth="150" text="CLASSIFICATION" />
                            <TableColumn fx:id="colQte" prefWidth="100" text="YIELD (ML)" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- Operations Sidebar Pane -->
                <VBox prefWidth="420.0" minWidth="420.0" styleClass="form-card" spacing="25.0">
                    <padding><Insets bottom="35.0" left="35.0" right="35.0" top="35.0" /></padding>

                    <VBox spacing="5">
                        <Label styleClass="form-section-title" text="DATA MANAGEMENT" />
                        <Label styleClass="admin-card-copy" text="Use the Dropdowns below to log or modify verified entry links safely." wrapText="true" />
                    </VBox>

                    <!-- 🔥 UPDATED FIELDS: COMBOBOX (DROPDOWNS) INSTEAD OF ID TEXT BOXES! -->
                    <VBox spacing="18">
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="DONOR / PATIENT RECORD" />
                            <ComboBox fx:id="clientBox" styleClass="combo-box" promptText="Select Patient..." maxWidth="Infinity" />
                        </VBox>
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="DESTINATION / ORIGIN FACILITY" />
                            <ComboBox fx:id="entityBox" styleClass="combo-box" promptText="Select Regional Branch..." maxWidth="Infinity" />
                        </VBox>
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="CLINICAL CATEGORY" />
                            <TextField fx:id="typeField" styleClass="dark-field" promptText="Ex: Full Blood / Plasma" />
                        </VBox>
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="AGGREGATE EXTRACT (ML)" />
                            <TextField fx:id="qteField" styleClass="dark-field" promptText="Ex: 450.0" />
                        </VBox>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <VBox spacing="15">
                        <Button onAction="#handleAddDonation" maxWidth="Infinity" styleClass="submit-button" text="Execute Addition Sequence" />
                        <HBox spacing="15">
                            <Button onAction="#handleUpdateDonation" maxWidth="Infinity" styleClass="cancel-button" text="Target Override" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleDeleteDonation" maxWidth="Infinity" styleClass="action-btn-delete" text="Expunge" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                </VBox>

            </HBox>
        </VBox>
    </HBox>
</StackPane>