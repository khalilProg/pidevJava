<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.FrontDonationController">
    <!-- Link your awesome global dark CSS here -->
    <stylesheets><URL value="@Front.css" /></stylesheets>

    <!-- Base Canvas with Hero glow effect from your CSS -->
    <VBox styleClass="hero-section">

        <!-- Modern Navbar (from your CSS) -->
        <HBox alignment="CENTER" styleClass="navbar-top">
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brand-section">
                <Circle fill="#e63939" radius="8.0" />
                <Label styleClass="brand-text" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="20.0" styleClass="nav-links-container">
                <Button onAction="#goToMyProfile" styleClass="nav-link" text="Health Passport" />
                <Label styleClass="nav-link-active" text="Donation Legacy" />

                <!-- Utilizing your beautiful user-pill CSS -->
                <HBox alignment="CENTER" styleClass="user-pill">
                    <Circle fill="#e63939" radius="10.0" />
                    <Label styleClass="user-name-label" text="Verified Donor" />
                </HBox>
                <Button onAction="#toggleMenu" styleClass="menu-button" text="SYSTEM ☰" />
            </HBox>
        </HBox>

        <!-- Dynamic Body Area -->
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox spacing="35.0" style="-fx-background-color: transparent;">
                <padding><Insets bottom="50.0" left="60.0" right="60.0" top="40.0" /></padding>

                <!-- Titles using your Hero styles -->
                <HBox alignment="BOTTOM_LEFT" spacing="20">
                    <VBox spacing="5.0">
                        <!-- THE '&' XML BUG IS FIXED HERE! -->
                        <Label styleClass="hero-title-large" text="Contribution Ledger" />
                        <Label styleClass="hero-description-v2" text="Verified decentralized tracking of extracted matter and saving volumes." />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <VBox alignment="CENTER" styleClass="stat-card" style="-fx-min-width: 150;">
                        <padding><Insets left="30" right="30" top="15" bottom="15"/></padding>
                        <Label styleClass="stat-card-subtitle" text="SYSTEM RANKING" />
                        <Label fx:id="rankLabel" styleClass="stat-card-title" text="INITIALIZING" />
                    </VBox>
                </HBox>

                <!-- 2 Columns Container -->
                <HBox spacing="35.0" VBox.vgrow="ALWAYS">
                    <!-- LEFT COLUMN: The Modern SaaS Table -->
                    <VBox spacing="20.0" HBox.hgrow="ALWAYS" styleClass="card">
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="card-title" text="OFFICIAL WITHDRAWALS" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" promptText="Search receipts..." styleClass="dark-input" />
                        </HBox>

                        <TableView fx:id="donationTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="120" text="RECEIPT ID" />
                                <TableColumn fx:id="colType" prefWidth="180" text="FLUID TYPE" />
                                <TableColumn fx:id="colQte" prefWidth="150" text="YIELD (ML)" />
                                <TableColumn fx:id="colEntityId" prefWidth="180" text="STATION ID" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>

                    <!-- RIGHT COLUMN: Impact and Charts -->
                    <VBox minWidth="400.0" prefWidth="420.0" spacing="25.0">

                        <!-- AI BUTTON CARD Using Your Glass styles -->
                        <VBox alignment="CENTER" spacing="15.0" styleClass="glass-card">
                            <padding><Insets bottom="40" left="30" right="30" top="40"/></padding>
                            <Label styleClass="glass-card-title" text="AI VITA-SPHERE IMPACT" />
                            <Label styleClass="hero-description-v2" style="-fx-text-alignment: center;" text="Neural network mapping ledger against local deficit volumes..." wrapText="true" />

                            <!-- Notice we mapped this perfectly to your 'btn-prime-home' class -->
                            <Button onAction="#runDeepImpactAnalysis" text="EXECUTE ALGORITHM ⚡" styleClass="btn-prime-home" />
                        </VBox>

                        <!-- Big Number Box -->
                        <VBox spacing="10.0" styleClass="glass-card">
                            <padding><Insets bottom="25" left="30" right="30" top="25"/></padding>
                            <Label styleClass="stat-card-subtitle" text="GROSS BIO-FLUID GIVEN" />
                            <HBox alignment="BASELINE_LEFT" spacing="10.0">
                                <Label fx:id="totalVolumeLabel" style="-fx-text-fill: white; -fx-font-size: 40px; -fx-font-weight: 900;" text="0.0" />
                                <Label style="-fx-text-fill: #e63939; -fx-font-weight: bold; -fx-font-size: 20px;" text="mL" />
                            </HBox>
                        </VBox>

                        <!-- Volume Trend Graph -->
                        <BarChart fx:id="yieldChart" styleClass="glass-card" legendVisible="false" horizontalGridLinesVisible="false" verticalGridLinesVisible="false" VBox.vgrow="ALWAYS" prefHeight="220">
                            <padding><Insets top="20" bottom="10" left="10" right="10" /></padding>
                            <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="#999999" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" tickLabelFill="#999999"/></yAxis>
                        </BarChart>

                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Navigation Slider Menu -->
    <Region fx:id="navBackdrop" mouseTransparent="true" onMouseClicked="#toggleMenu" opacity="0.0" style="-fx-background-color: rgba(0,0,0,0.85);" />
    <VBox fx:id="navMenuPanel" maxWidth="350.0" prefWidth="350.0" spacing="30.0" styleClass="menu-panel" translateX="450.0" StackPane.alignment="CENTER_RIGHT">
        <padding><Insets left="40.0" top="80.0" right="40.0" /></padding>
        <Label style="-fx-text-fill: #e63939; -fx-font-weight: 900; -fx-letter-spacing: 2px;" text="SYSTEM NAVIGATOR" />
        <Button onAction="#goToMyProfile" styleClass="menu-link" text="► MY HEALTH DATA" />
        <Button onAction="#toggleMenu" styleClass="menu-link" style="-fx-text-fill: white;" text="► MY DONATIONS" />
        <Region VBox.vgrow="ALWAYS" />
        <Button styleClass="btn-outline" text="LOG OUT / ABORT" maxWidth="Infinity"/>
    </VBox>

    <!-- FULLSCREEN AI OVERLAY - No backdrop-filter blur! -->
    <StackPane fx:id="aiOverlay" mouseTransparent="true" visible="false" style="-fx-background-color: rgba(10,10,10,0.92);">
        <VBox maxWidth="800" maxHeight="500" spacing="30" alignment="CENTER" styleClass="glass-card" style="-fx-border-color: #e63939;">
            <padding><Insets bottom="60" left="60" right="60" top="60" /></padding>
            <HBox alignment="CENTER" spacing="15">
                <Circle radius="6" fill="#00ff88"/>
                <Label styleClass="hero-title-large" style="-fx-font-size: 26;" text="SYNTHESIS REPORT" />
            </HBox>
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <Label fx:id="overlayAiText" wrapText="true" style="-fx-text-fill: #e0e0e0; -fx-font-size: 18px; -fx-line-spacing: 8px;" text="Executing computations..." />
            </ScrollPane>
            <!-- Closes using your dark style class -->
            <Button onAction="#closeAIOverlay" text="CLOSE INTELLIGENCE PANEL" styleClass="btn-primary-modern" />
        </VBox>
    </StackPane>

</StackPane>