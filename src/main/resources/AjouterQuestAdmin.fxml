<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane stylesheets="@commande.css" styleClass="main-container" prefHeight="900.0" prefWidth="1400.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AjouterQuestAdmin">
   <!-- Sidebar -->
   <left><fx:include fx:id="sidebar" source="admin_sidebar.fxml" /></left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="25.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         
         <!-- Header -->
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label styleClass="admin-page-title" text="NOUVEAU QUESTIONNAIRE" />
                <Label styleClass="admin-page-subtitle" text="Saisie administrative des informations du donneur." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
         </HBox>

         <!-- Form Card -->
         <VBox styleClass="glass-card" spacing="25.0" VBox.vgrow="ALWAYS">
            
            <!-- Row 1: Age + Sexe -->
            <HBox spacing="20.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="ÂGE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <TextField fx:id="ageField" promptText="Ex: 25" styleClass="text-field-custom" />
                    <Text fx:id="ageError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="SEXE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <ComboBox styleClass="dark-combo" fx:id="sexeCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionner">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Homme"/>
                                <String fx:value="Femme"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Text fx:id="sexeError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
            </HBox>

            <!-- Row 2: Poids + Campagne -->
            <HBox spacing="20.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="POIDS (KG)" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <TextField fx:id="poidsField" promptText="Ex: 70" styleClass="text-field-custom" />
                    <Text fx:id="poidsError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="CAMPAGNE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <ComboBox styleClass="dark-combo" fx:id="campagneCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionner une campagne" />
                    <Text fx:id="campagneError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
            </HBox>

            <!-- Row 3: Phone -->
            <VBox spacing="8.0">
                <Label text="TÉLÉPHONE DU DONNEUR" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                <TextField fx:id="phoneField" promptText="Ex: +21612345678" styleClass="text-field-custom" />
                <Text fx:id="phoneError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
            </VBox>

            <!-- Row 4: Autres -->
            <VBox spacing="8.0">
                <Label text="AUTRES INFORMATIONS" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                <TextArea styleClass="dark-field" fx:id="autresField" promptText="Antécédents, allergies, traitements en cours..." prefHeight="100.0" />
            </VBox>

            <!-- Buttons -->
            <HBox spacing="15.0" alignment="CENTER_RIGHT">
                <Button styleClass="cancel-button" fx:id="annulerBtn" text="ANNULER" onAction="#handleNavigateQuestionnaires" />
                <Button fx:id="continuerBtn" text="CONTINUER →" onAction="#handleContinuer" styleClass="button-primary" />
            </HBox>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>
