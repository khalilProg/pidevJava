<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<AnchorPane prefHeight="800.0" prefWidth="1550.0" styleClass="root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AjouterQuestAdmin">
    <fx:include source="BaseBack.fxml" fx:id="headerInclude" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"/>

    <children>
        <VBox layoutX="30.0" layoutY="110.0" spacing="20.0" AnchorPane.leftAnchor="670">
            <children>
                <VBox spacing="8.0">
                    <children>
                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Remplir le questionnaire" styleClass="hero-title">
                            <font>
                                <Font size="36.0" />
                            </font>
                        </Text>
                        <Text fill="#888888" strokeType="OUTSIDE" strokeWidth="0.0" text="Saisie administrative des informations du donneur.">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Text>
                    </children>
                </VBox>

                <VBox prefWidth="500.0" prefHeight="100.0" spacing="10.0">
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="ÂGE" styleClass="stat-card-subtitle" />
                                        <TextField fx:id="ageField" promptText="Ex: 25"/>
                                        <Text fx:id="ageError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="SEXE" styleClass="stat-card-subtitle" />
                                        <ComboBox fx:id="sexeCombo" prefWidth="400.0">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="Homme"/>
                                                    <String fx:value="Femme"/>
                                                </FXCollections>
                                            </items>
                                        </ComboBox>
                                        <Text fx:id="sexeError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="POIDS (KG)" styleClass="stat-card-subtitle" />
                                        <TextField fx:id="poidsField" promptText="Ex: 70"/>
                                        <Text fx:id="poidsError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="CAMPAGNE" styleClass="stat-card-subtitle" />
                                        <ComboBox fx:id="campagneCombo" prefWidth="400.0"/>
                                        <Text fx:id="campagneError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="PHONE" styleClass="stat-card-subtitle" />
                                <TextField fx:id="phoneField" promptText="Ex: +21612345678"/>
                                <Text fx:id="phoneError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="AUTRES INFORMATIONS" styleClass="stat-card-subtitle" />
                                <TextArea fx:id="autresField" promptText="Antécédents, allergies, traitements en cours..." prefHeight="100.0"/>
                            </children>
                        </VBox>

                        <HBox spacing="20" alignment="CENTER_RIGHT">
                           <padding>
                               <Insets top="10.0"/>
                           </padding>
                            <Button fx:id="continuerBtn" text="CONTINUER" onAction="#handleContinuer" styleClass="btn-primary-modern"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
