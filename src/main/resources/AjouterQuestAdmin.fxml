<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AjouterQuestAdmin">
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item, sidebar-item-active" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Admin Utilisateur" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="25.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         
         <!-- Header -->
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="NOUVEAU QUESTIONNAIRE" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Saisie administrative des informations du donneur." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
         </HBox>

         <!-- Form Card -->
         <VBox styleClass="glass-card" spacing="25.0" VBox.vgrow="ALWAYS">
            
            <!-- Row 1: Age + Sexe -->
            <HBox spacing="20.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="ÂGE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <TextField fx:id="ageField" promptText="Ex: 25" styleClass="text-field-custom" />
                    <Text fx:id="ageError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="SEXE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <ComboBox fx:id="sexeCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionner" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Homme"/>
                                <String fx:value="Femme"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Text fx:id="sexeError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
            </HBox>

            <!-- Row 2: Poids + Campagne -->
            <HBox spacing="20.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="POIDS (KG)" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <TextField fx:id="poidsField" promptText="Ex: 70" styleClass="text-field-custom" />
                    <Text fx:id="poidsError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="CAMPAGNE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                    <ComboBox fx:id="campagneCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionner une campagne" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8;" />
                    <Text fx:id="campagneError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
                </VBox>
            </HBox>

            <!-- Row 3: Phone -->
            <VBox spacing="8.0">
                <Label text="TÉLÉPHONE DU DONNEUR" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                <TextField fx:id="phoneField" promptText="Ex: +21612345678" styleClass="text-field-custom" />
                <Text fx:id="phoneError" fill="#FF3E3E" visible="false" style="-fx-font-size: 11px;" />
            </VBox>

            <!-- Row 4: Autres -->
            <VBox spacing="8.0">
                <Label text="AUTRES INFORMATIONS" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: 800;" />
                <TextArea fx:id="autresField" promptText="Antécédents, allergies, traitements en cours..." prefHeight="100.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-control-inner-background: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8;" />
            </VBox>

            <!-- Buttons -->
            <HBox spacing="15.0" alignment="CENTER_RIGHT">
                <Button fx:id="annulerBtn" text="ANNULER" onAction="#handleNavigateQuestionnaires" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 20px; -fx-text-fill: white; -fx-padding: 10 25; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button fx:id="continuerBtn" text="CONTINUER →" onAction="#handleContinuer" styleClass="button-primary" style="-fx-background-radius: 20px; -fx-padding: 10 25;" />
            </HBox>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>
