<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane stylesheets="@commande.css" fx:id="menuContainer" prefHeight="800.0" prefWidth="1200.0"  style="-fx-background-color: rgba(10,10,10,0.86);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.custom_menu">
   <children>
      <!-- Top Bar matching the transparent menu bar -->
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="header-bar" style="-fx-background-color: transparent;">
         <children>
            <Label text="BLOODLINK" styleClass="logo-text" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" styleClass="menu-toggle" text="FERMER" onAction="#handleCloseMenu" />
         </children>
      </HBox>

      <!-- Slide-in Panel (Right anchored) -->
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" prefWidth="520.0" styleClass="menu-panel" alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" styleClass="menu-link" text="ACCUEIL" />
            <Button mnemonicParsing="false" onAction="#handleGoToLogin" styleClass="menu-link" text="SE CONNECTER" />
            <Button mnemonicParsing="false" onAction="#handleGoToRegister" styleClass="menu-link" text="CRÉER COMPTE" />
            
            <VBox spacing="10.0">
               <VBox.margin>
                  <Insets top="40.0" />
               </VBox.margin>
               <children>
                  <Label styleClass="subtitle-text" text="Rejoignez la communauté des sauveurs de vie." />
                  <Button styleClass="submit-button" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="➜ Se connecter" onAction="#handleGoToLogin" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>

