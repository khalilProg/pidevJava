<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="900.0" prefWidth="1550.0" stylesheets="@client-campagnes.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ListeCampagnes">
   <children>
      <AnchorPane styleClass="client-campaign-root">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="nav-bar">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="6">
                     <Label styleClass="brand-label" text="BLOODLINK" />
                  </HBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleThemeToggle" styleClass="theme-toggle-btn" text="Light" />
                  <Region prefWidth="12.0" />
                  <Button fx:id="userNameBtn" mnemonicParsing="false" styleClass="user-badge" text="Utilisateur" />
                  <Region prefWidth="12.0" />
                  <Button fx:id="menuToggleBtn" mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="menu-toggle" text="MENU" />
               </children>
            </HBox>

            <VBox spacing="24.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="85.0">
               <padding>
                  <Insets bottom="30.0" left="42.0" right="42.0" top="32.0" />
               </padding>
               <children>
                  <HBox spacing="24.0" styleClass="campaign-hero">
                     <children>
                        <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="eyebrow" text="CLIENT SPACE" />
                              <Label styleClass="hero-title" text="Trouvez une campagne qui vous correspond" wrapText="true" />
                              <Label styleClass="hero-subtitle" text="Une experience visuelle orientee cartes pour explorer les campagnes de don sans affichage tableau." wrapText="true" />
                           </children>
                        </VBox>
                        <VBox spacing="14.0" styleClass="hero-side-card">
                           <children>
                              <Label styleClass="hero-side-title" text="Vue rapide" />
                              <Label fx:id="campaignCountLabel" styleClass="hero-side-count" text="0 campagnes disponibles" />
                              <Label styleClass="hero-side-copy" text="Filtrez par titre, description ou groupe sanguin et entrez directement dans une campagne." wrapText="true" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="toolbar-shell">
                     <children>
                        <TextField fx:id="searchField" prefHeight="46.0" prefWidth="420.0" promptText="Rechercher une campagne, un besoin ou un groupe sanguin..." styleClass="search-field" />
                        <Label styleClass="toolbar-note" text="Affichage 100% cartes" />
                     </children>
                  </HBox>

                  <StackPane VBox.vgrow="ALWAYS">
                     <children>
                        <VBox fx:id="emptyState" alignment="CENTER" managed="false" spacing="10.0" styleClass="empty-state">
                           <children>
                              <Label styleClass="empty-title" text="Aucune campagne trouvee" />
                              <Label styleClass="empty-copy" text="Essayez une autre recherche ou revenez plus tard pour de nouvelles campagnes." wrapText="true" />
                           </children>
                        </VBox>

                        <ScrollPane fitToWidth="true" styleClass="campaign-scroll">
                           <content>
                              <FlowPane fx:id="campaignContainer" hgap="22.0" prefWrapLength="1400.0" styleClass="campaign-flow" vgap="22.0" />
                           </content>
                        </ScrollPane>
                     </children>
                  </StackPane>
               </children>
            </VBox>
         </children>
      </AnchorPane>

      <HBox fx:id="menuOverlay" alignment="CENTER_RIGHT" managed="false" visible="false">
         <children>
            <Region onMouseClicked="#handleMenuClose" styleClass="menu-backdrop" HBox.hgrow="ALWAYS" />
            <VBox fx:id="menuPanel" alignment="TOP_LEFT" prefWidth="380.0" spacing="15.0" styleClass="menu-panel">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="submit-button" text="FERMER" />
                     </children>
                  </HBox>
                  <Region prefHeight="20.0" />
                  <Button mnemonicParsing="false" onAction="#goToAccueil" styleClass="menu-link" text="ACCUEIL" />
                  <Button mnemonicParsing="false" onAction="#goToCampagnes" styleClass="menu-link, menu-link-active" text="CAMPAGNES" />
                  <Button mnemonicParsing="false" onAction="#goToHistorique" styleClass="menu-link" text="HISTORIQUE" />
                  <Button mnemonicParsing="false" onAction="#goToCommandes" styleClass="menu-link" text="COMMANDES" />
                  <Button mnemonicParsing="false" styleClass="menu-link" text="DOSSIER MEDICAL" />
                  <Button mnemonicParsing="false" onAction="#goToProfile" styleClass="menu-link" text="MON PROFIL" />
                  <Region VBox.vgrow="ALWAYS" />
                  <VBox spacing="15.0">
                     <children>
                        <Label fx:id="sessionEmailLabel" styleClass="menu-session" text="Session: utilisateur@email.com" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="submit-button" text="DECONNEXION" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</StackPane>
