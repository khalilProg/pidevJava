<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>


<?import java.lang.String?>
<AnchorPane prefHeight="800.0" prefWidth="1550.0" styleClass="root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.Update">
    <fx:include source="BaseFront.fxml" fx:id="headerInclude" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"/>

    <children>
        <VBox layoutX="70.0" layoutY="110.0" spacing="30.0" AnchorPane.leftAnchor="280.0">
            <children>
                <VBox spacing="8.0">
                    <children>
                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Modifier le Rendez-vous et Questionnaire" styleClass="hero-title">
                            <font>
                                <Font size="36.0" />
                            </font>
                        </Text>
                        <Text fill="#888888" strokeType="OUTSIDE" strokeWidth="0.0" text="Mettez à jour vos informations de participation.">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Text>
                    </children>
                </VBox>

                <HBox spacing="50.0">
                    <children>
                        <!-- Left Side: Questionnaire Info -->
                        <VBox prefWidth="500.0" spacing="15.0">
                            <children>
                                <Label text="Informations personnelles" styleClass="stat-card-title" style="-fx-font-size: 24px; -fx-font-weight: 900;"/>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Âge" styleClass="stat-card-subtitle" />
                                        <TextField fx:id="ageField"/>
                                        <Text fx:id="ageError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Sexe" styleClass="stat-card-subtitle" />
                                        <ComboBox fx:id="sexeCombo" prefWidth="450.0">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="Homme"/>
                                                    <String fx:value="Femme"/>
                                                </FXCollections>
                                            </items>
                                        </ComboBox>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Poids (kg)" styleClass="stat-card-subtitle" />
                                        <TextField fx:id="poidsField"/>
                                        <Text fx:id="poidsError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Autres" styleClass="stat-card-subtitle" />
                                        <TextArea fx:id="autresField" prefHeight="100.0"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Right Side: Rendez-vous Info -->
                        <VBox prefWidth="500.0" spacing="15.0">
                            <children>
                                <Label text="Détails du rendez-vous" styleClass="stat-card-title" style="-fx-font-size: 24px; -fx-font-weight: 900;" />
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Date du rendez-vous" styleClass="stat-card-subtitle" />
                                        <DatePicker fx:id="dateRdvPicker" prefWidth="450.0"/>
                                        <Text fx:id="dateError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Heure" styleClass="stat-card-subtitle" />
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <Spinner fx:id="hourSpinner" prefWidth="80.0"/>
                                                <Label text="h" styleClass="stat-card-subtitle" />
                                                <Spinner fx:id="minuteSpinner" prefWidth="80.0"/>
                                                <Label text="m" styleClass="stat-card-subtitle" />
                                            </children>
                                        </HBox>
                                        <Text fx:id="timeError" fill="#FF3E3E" visible="false" styleClass="error-text"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Entité de collecte" styleClass="stat-card-subtitle" />
                                        <ComboBox fx:id="entiteCombo" prefWidth="450.0"/>
                                    </children>
                                </VBox>

                                <HBox spacing="20" alignment="BOTTOM_RIGHT" VBox.vgrow="ALWAYS">
                                   <padding>
                                       <Insets top="20.0"/>
                                   </padding>
                                    <Button fx:id="confirmerBtn" text="Sauvegarder les modifications" onAction="#handleConfirmer" styleClass="btn-primary-modern" />
                                    <Button fx:id="annulerBtn" text="Annuler" onAction="#handleAnnuler" styleClass="btn-outline"/>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>