<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ListeCampagnesAdmin">
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <!-- Logo -->
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item, sidebar-item-active" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Admin Utilisateur" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="35.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         
         <!-- Header -->
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="Gestion des Campagnes" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Interface d'administration" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addBtn" mnemonicParsing="false" onAction="#handleAjouter" style="-fx-background-radius: 20px; -fx-padding: 10px 25px; -fx-font-weight: 800;" styleClass="button-primary" text="+ Nouvelle Campagne" />
         </HBox>

         <!-- Statistiques Section -->
         <HBox prefHeight="350.0" spacing="20.0">
            <children>
               <!-- BarChart -->
               <VBox spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                  <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                  <children>
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 16px;" text="Aperçu des Campagnes" />
                     <BarChart fx:id="campagneChart" legendVisible="false" style="-fx-text-fill: white;" verticalGridLinesVisible="false">
                        <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="WHITE" /></xAxis>
                        <yAxis><NumberAxis side="LEFT" tickLabelFill="WHITE" /></yAxis>
                     </BarChart>
                  </children>
               </VBox>
               
               <!-- Top 3 Months -->
               <VBox fx:id="topMonthsContainer" prefWidth="300.0" spacing="15.0" styleClass="glass-card">
                  <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                  <children>
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 16px;" text="Top Mois Actifs" />
                     <VBox fx:id="topMonthsList" spacing="10.0" />
                  </children>
               </VBox>
            </children>
         </HBox>

         <VBox styleClass="glass-card" spacing="30.0" VBox.vgrow="ALWAYS">
            
            <!-- Filter Section -->
            <HBox spacing="20.0" alignment="CENTER_LEFT">
               <HBox spacing="10.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-padding: 5px 15px;">
                   <Label text="🔍" style="-fx-text-fill: -muted;" />
                   <TextField fx:id="searchField" promptText="Rechercher une campagne..." style="-fx-background-color: transparent; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
               </HBox>
               <ComboBox fx:id="sortComboBox" promptText="Trier par..." prefWidth="250.0" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-text-fill: white; -fx-padding: 5px;" />
            </HBox>

            <!-- Table -->
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS" stylesheets="@styles.css">
               <columns>
                  <TableColumn fx:id="titreColumn" text="TITRE" prefWidth="180" />
                  <TableColumn fx:id="descColumn" text="DESCRIPTION" prefWidth="200" />
                  <TableColumn fx:id="entiteColumn" text="ENTITÉS" prefWidth="220" />
                  <TableColumn fx:id="typesSangColumn" text="TYPES DE SANG" prefWidth="150" />
                  <TableColumn fx:id="datesColumn" text="DATES" prefWidth="150" />
                  <TableColumn fx:id="actionsColumn" text="ACTIONS" prefWidth="150" />
               </columns>
            </TableView>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>
