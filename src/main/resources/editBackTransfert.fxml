<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.EditTransfertController">
   
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item, sidebar-item-active" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Admin Utilisateur" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retour" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>

   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <!-- HEADER -->
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label fx:id="titleLabel" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="MODIFIER TRANSFERT" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Modifier les informations du transfert de sang." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="← RETOUR" onAction="#retour" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
         </HBox>

         <!-- FORM CARD -->
         <VBox styleClass="glass-card" spacing="30.0" maxWidth="800">
             
            <Label style="-fx-text-fill: #e63939; -fx-font-weight: 900; -fx-font-size: 18px;" text="DÉTAILS DU TRANSFERT" />

            <GridPane hgap="30" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>
                
                <!-- ORIGINE -->
                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="form-label" text="ORGANISATION ORIGINE" />
                    <TextField promptText="BloodLink Central" styleClass="text-field-custom" />
                </VBox>
                <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="form-label" text="ID ORIGINE" />
                    <TextField fx:id="txtFrom" promptText="0" styleClass="text-field-custom" />
                    <Label fx:id="txtFromError" styleClass="field-error" managed="false" visible="false" />
                </VBox>

                <!-- DESTINATION -->
                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label styleClass="form-label" text="ORGANISATION DESTINATION" />
                    <TextField promptText="Hopital Ariena" styleClass="text-field-custom" />
                </VBox>
                <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label styleClass="form-label" text="ID DESTINATION" />
                    <TextField fx:id="txtTo" promptText="41" styleClass="text-field-custom" />
                    <Label fx:id="txtToError" styleClass="field-error" managed="false" visible="false" />
                </VBox>

                <!-- QUANTITE & DATES -->
                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label styleClass="form-label" text="QUANTITÉ" />
                    <TextField fx:id="txtQuantite" promptText="50" styleClass="text-field-custom" />
                    <Label fx:id="txtQuantiteError" styleClass="field-error" managed="false" visible="false" />
                </VBox>
                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="DATE D'ENVOI" />
                        <DatePicker fx:id="dateEnvoie" styleClass="text-field-custom" maxWidth="1.7976931348623157E308"/>
                        <Label fx:id="dateEnvoieError" styleClass="field-error" managed="false" visible="false" />
                    </VBox>
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="DATE DE RÉCEPTION" />
                        <DatePicker fx:id="dateReception" styleClass="text-field-custom" maxWidth="1.7976931348623157E308"/>
                        <Label fx:id="dateReceptionError" styleClass="field-error" managed="false" visible="false" />
                    </VBox>
                </HBox>

                <!-- STATUT, STOCK, DEMANDE -->
                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label styleClass="form-label" text="STATUT" />
                    <ComboBox fx:id="comboStatus" promptText="En cours" styleClass="text-field-custom" prefWidth="600" />
                    <Label fx:id="comboStatusError" styleClass="field-error" managed="false" visible="false" />
                </VBox>
                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="STOCK" />
                        <TextField promptText="A+" styleClass="text-field-custom" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="DEMANDE" />
                        <TextField promptText="12" styleClass="text-field-custom" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </HBox>
            </GridPane>

            <Region prefHeight="10" />

            <HBox spacing="15.0" alignment="CENTER_RIGHT">
                <Button mnemonicParsing="false" onAction="#retour" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" text="ANNULER" />
                <Button mnemonicParsing="false" onAction="#updateTransfert" styleClass="button-primary" text="✓ ENREGISTRER" prefWidth="180" />
            </HBox>
            
         </VBox>

      </VBox>
   </center>
</BorderPane>
