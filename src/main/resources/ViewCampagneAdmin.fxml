<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ViewCampagneAdmin">
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item, sidebar-item-active" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item" text="🏥  Collectes" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="khalilboujemaa@gmail" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <center>
      <ScrollPane fitToWidth="true" styleClass="main-content-scroll" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
         <VBox styleClass="main-content" spacing="40.0">
            <padding>
               <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
            </padding>
            
            <HBox alignment="CENTER_LEFT">
               <VBox spacing="5.0">
                   <Label fx:id="titreHeaderLabel" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="DÉTAILS DE LA CAMPAGNE" />
                   <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Informations sur la mobilisation et lieux de collecte." />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <HBox spacing="15.0">
                   <Button mnemonicParsing="false" text="← RETOUR" onAction="#handleRetour" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
                   <Button mnemonicParsing="false" text="✏ MODIFIER" onAction="#handleNavigateModifier" styleClass="button-primary" style="-fx-background-radius: 20; -fx-padding: 8 20;" />
               </HBox>
            </HBox>
            
            <VBox styleClass="glass-card" spacing="30.0" maxWidth="900.0" style="-fx-padding: 40;">
                <VBox spacing="10.0">
                    <Label fx:id="titreLabel" text="Campagne de Printemps" style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 30px;" />
                    <HBox spacing="15.0">
                        <Label fx:id="datesLabel" text="📅 01/04/2026 — 15/04/2026" style="-fx-text-fill: -primary; -fx-font-weight: bold; -fx-font-size: 14px;" />
                        <Label fx:id="idLabel" text="#123" style="-fx-text-fill: -muted; -fx-font-size: 14px;" />
                    </HBox>
                </VBox>

                <Region prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.05);" />

                <VBox spacing="15.0">
                    <Label text="DESCRIPTION" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                    <Label fx:id="descLabel" text="Description de la campagne ici..." style="-fx-text-fill: white; -fx-font-size: 15px; -fx-line-spacing: 5;" wrapText="true" />
                </VBox>

                <VBox spacing="15.0">
                    <Label text="GROUPES SANGUINS CIBLÉS" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                    <FlowPane fx:id="bloodTypesFlowPane" hgap="10.0" vgap="10.0" />
                </VBox>

                <VBox spacing="15.0">
                    <Label text="LIEUX DE COLLECTE" style="-fx-text-fill: -muted; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                    <FlowPane fx:id="entitesFlowPane" hgap="10.0" vgap="10.0" />
                </VBox>
            </VBox>
         </VBox>
      </ScrollPane>
   </center>
</BorderPane>
