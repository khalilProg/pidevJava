<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>
<VBox spacing="20" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-width: 2; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 30;"
      stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AIResultController" prefWidth="650">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane style="-fx-background-color: #2a1111; -fx-background-radius: 10; -fx-padding: 10;">
            <SVGPath content="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z" fill="#E53935" scaleX="1.2" scaleY="1.2"/>
        </StackPane>
        <VBox>
            <Label text="ANALYSE INTELLIGENTE" style="-fx-text-fill: #E53935; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            <Label text="Prédictions &amp; Recommandations" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <WebView fx:id="resultWebView" prefHeight="450" />

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Fermer l'analyse" onAction="#closeModal" styleClass="btn-primary" prefWidth="150" style="-fx-padding: 10 20;"/>
    </HBox>
</VBox>
