<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@commande.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueTransfertController" spacing="30"
      styleClass="main-content" style="-fx-padding: 40 50;">

    <!-- Top Header -->
    <VBox spacing="5">
        <Label text="BLOODLINK" styleClass="breadcrumb-label" />
        <Label text="Transferts" styleClass="admin-page-title" />
        <Label text="Suivez les transferts de sang entre les organisations." styleClass="page-subtitle" />
    </VBox>

    <!-- Filter Bar -->
    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="form-card" style="-fx-padding: 15 20;">
        <TextField fx:id="txtSearch" promptText="Rechercher par destination, statut..." styleClass="dark-field" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="comboStatusFilter" promptText="Tous les statuts" styleClass="dark-combo" prefWidth="250"/>
    </HBox>

    <!-- Table Container -->
    <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
        <HBox alignment="CENTER_LEFT" style="-fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 10 0;">
            <Label text="LISTE DES TRANSFERTS" styleClass="breadcrumb-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblCount" text="0 transfert(s)" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        </HBox>
        <ScrollPane fitToWidth="true" styleClass="edge-to-edge-scroll" VBox.vgrow="ALWAYS">
            <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;" />
        </ScrollPane>
    </VBox>

</VBox>
