<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueTransfertController" spacing="30"
      style="-fx-background-color: #0d0d0d; -fx-padding: 40 50;">

    <!-- Top Header -->
    <VBox spacing="5">
        <Label text="BLOODLINK" styleClass="page-subtitle" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <SVGPath content="M19 4h-4V2H9v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-7-2h4v2h-4V2zM7 10h10v2H7v-2zm0 4h10v2H7v-2z" fill="#E53935" scaleX="1.3" scaleY="1.3"/>
            <Label text="Transferts" styleClass="page-title"/>
        </HBox>
        <Label text="Suivez les transferts de sang entre les organisations." styleClass="page-subtitle"/>
    </VBox>

    <!-- Filter Bar -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #111111; -fx-border-color: #222222; -fx-border-radius: 10px; -fx-padding: 15;">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #0A0A0A; -fx-border-color: #E53935; -fx-border-radius: 5px; -fx-padding: 0 10;">
            <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#555555"/>
            <TextField fx:id="txtSearch" promptText="Rechercher par destination, statut..." styleClass="search-field" style="-fx-background-color: transparent; -fx-border-color: transparent;" HBox.hgrow="ALWAYS"/>
        </HBox>
        
        <ComboBox fx:id="comboStatusFilter" promptText="Tous les statuts" styleClass="dark-combo-box" prefWidth="250"/>
    </HBox>

    <!-- Table Container -->
    <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
        <HBox alignment="CENTER_LEFT" style="-fx-border-color: #222222; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 10 0;">
            <Label text="LISTE DES TRANSFERTS" style="-fx-text-fill: #555555; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblCount" text="0 transfert(s)" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        </HBox>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS">
            <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;" />
        </ScrollPane>
    </VBox>

</VBox>
