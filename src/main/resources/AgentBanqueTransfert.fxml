<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueTransfertController" spacing="30"
      styleClass="main-content agent-page agent-transferts-page">

    <HBox alignment="CENTER_LEFT" spacing="24">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" styleClass="agent-kicker"/>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <SVGPath content="M19 4h-4V2H9v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-7-2h4v2h-4V2zM7 10h10v2H7v-2zm0 4h10v2H7v-2z" fill="#E53935" scaleX="1.3" scaleY="1.3"/>
                <Label text="Transferts" styleClass="agent-title"/>
            </HBox>
            <Label text="Suivez les transferts de sang entre les organisations." styleClass="agent-subtitle"/>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button text="📊 Exporter Excel" styleClass="btn-secondary btn-excel" onAction="#handleExportExcel"/>
            <Button text="📈 Statistiques" styleClass="btn-secondary btn-info" onAction="#showStats"/>
        </HBox>
    </HBox>

    <VBox styleClass="glass-card" spacing="20" VBox.vgrow="ALWAYS">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="400" styleClass="agent-search-box">
                <FontIcon iconLiteral="fas-search" iconSize="13" styleClass="agent-search-icon"/>
                <TextField fx:id="txtSearch" promptText="Rechercher par destination, statut..." styleClass="transparent-input" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="comboStatusFilter" promptText="Tous les statuts" styleClass="filter-btn" prefWidth="250"/>
        </HBox>

        <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" styleClass="agent-section-header">
                <Label text="LISTE DES TRANSFERTS" styleClass="agent-section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCount" text="0 transfert(s)" styleClass="agent-count-label"/>
            </HBox>
            <ScrollPane fitToWidth="true" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS">
                <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;"/>
            </ScrollPane>
        </VBox>
    </VBox>

</VBox>
