<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ListeQuestAdmin">
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <!-- Logo -->
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item, sidebar-item-active" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Admin Utilisateur" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="35.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         
         <!-- Header -->
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="QUESTIONNAIRES" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Consultez et gérez les questionnaires des donneurs." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15.0" alignment="CENTER">
               <Button text="📥" style="-fx-background-color: transparent; -fx-border-color: rgba(230,57,57,0.5); -fx-text-fill: #e63939; -fx-border-radius: 20px; -fx-padding: 10px 15px; -fx-cursor: hand;" />
               <Button fx:id="addBtn" mnemonicParsing="false" text="+ NOUVEAU QUESTIONNAIRE" onAction="#handleAjouter" styleClass="button-primary" style="-fx-background-radius: 20px; -fx-padding: 10px 25px;" />
            </HBox>
         </HBox>

         <VBox styleClass="glass-card" spacing="30.0" VBox.vgrow="ALWAYS">
            
            <!-- Filter Section -->
            <VBox spacing="20.0">
               <!-- Filter Row 1 -->
               <HBox spacing="20.0">
                  <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                     <Label text="RECHERCHE" styleClass="filter-label" />
                     <TextField promptText="Nom ou Prénom..." styleClass="text-field-custom" />
                  </VBox>
                  <VBox spacing="8.0" prefWidth="300.0">
                     <Label text="GROUPE SANGUIN" styleClass="filter-label" />
                     <ComboBox promptText="Tous les groupes" maxWidth="1.7976931348623157E308" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-text-fill: white; -fx-padding: 5px;" />
                  </VBox>
                  <VBox spacing="8.0" prefWidth="300.0">
                     <Label text="CAMPAGNE" styleClass="filter-label" />
                     <ComboBox promptText="Toutes les campagnes" maxWidth="1.7976931348623157E308" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-text-fill: white; -fx-padding: 5px;" />
                  </VBox>
               </HBox>
               <!-- Filter Row 2 -->
               <HBox spacing="20.0" alignment="BOTTOM_LEFT">
                  <VBox spacing="8.0" prefWidth="250.0">
                     <Label text="DATE" styleClass="filter-label" />
                     <DatePicker promptText="mm / dd / yyyy" maxWidth="1.7976931348623157E308" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;" />
                  </VBox>
                  <VBox spacing="8.0" prefWidth="250.0">
                     <Label text="HEURE" styleClass="filter-label" />
                     <TextField promptText="--:-- --" styleClass="text-field-custom" />
                  </VBox>
                  <VBox spacing="8.0" prefWidth="250.0">
                     <Label text="TRI" styleClass="filter-label" />
                     <ComboBox promptText="Ordre par défaut" maxWidth="1.7976931348623157E308" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-text-fill: white; -fx-padding: 5px;" />
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button text="↺ RÉINITIALISER" style="-fx-background-color: transparent; -fx-border-color: #e63939; -fx-text-fill: #e63939; -fx-font-weight: 800; -fx-border-radius: 20px; -fx-padding: 10px 25px; -fx-cursor: hand;" />
               </HBox>
            </VBox>

            <!-- Table -->
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS" stylesheets="@styles.css">
               <columns>
                  <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                  <TableColumn fx:id="donneurColumn" text="DONNEUR" prefWidth="300" />
                  <TableColumn fx:id="typeSangColumn" text="GROUPE" prefWidth="120" />
                  <TableColumn fx:id="campagneColumn" text="CAMPAGNE" prefWidth="150" />
                  <TableColumn fx:id="dateColumn" text="DATE" prefWidth="200" />
                  <TableColumn fx:id="actionsColumn" text="ACTIONS" prefWidth="120" />
               </columns>
            </TableView>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>
