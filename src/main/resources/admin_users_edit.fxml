<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AdminUsersEditController">
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         
         <Label styleClass="sidebar-category" text="GESTION" />
         
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item, sidebar-item-active" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="khalilboujemaa@gmail" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="MODIFIER UTILISATEUR" />
                <Label fx:id="subtitleLabel" style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Mettre à jour les informations du compte." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="← RETOUR" onAction="#handleNavigateUsers" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
         </HBox>
         
         <VBox styleClass="glass-card" spacing="25.0" maxWidth="800.0" alignment="CENTER_LEFT" style="-fx-padding: 40;">
             <Label style="-fx-text-fill: -primary; -fx-font-weight: 900; -fx-font-size: 18px;" text="INFORMATIONS DU PROFIL" />
             
             <!-- Row 1: Prenom & Nom -->
             <HBox spacing="20.0">
                 <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="form-label" text="PRÉNOM" />
                     <TextField fx:id="prenomF" promptText="Ex: Jean" styleClass="text-field-custom" />
                     <Label fx:id="prenomError" styleClass="field-error" text="" visible="false" managed="false" />
                 </VBox>
                 <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="form-label" text="NOM" />
                     <TextField fx:id="nomF" promptText="Ex: Dupont" styleClass="text-field-custom" />
                     <Label fx:id="nomError" styleClass="field-error" text="" visible="false" managed="false" />
                 </VBox>
             </HBox>
             
             <!-- Row 2: Email -->
             <VBox spacing="3.0">
                 <Label styleClass="form-label" text="EMAIL" />
                 <TextField fx:id="emailF" promptText="jean.dupont@exemple.com" styleClass="text-field-custom" />
                 <Label fx:id="emailError" styleClass="field-error" text="" visible="false" managed="false" />
             </VBox>
             
             <!-- Row 3: Pass (optional) & Role -->
             <HBox spacing="20.0">
                 <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="form-label" text="MOT DE PASSE (Optionnel)" />
                     <PasswordField fx:id="passF" promptText="Laissez vide pour conserver l'actuel" styleClass="text-field-custom" />
                     <Label fx:id="passError" styleClass="field-error" text="" visible="false" managed="false" />
                 </VBox>
                 <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="form-label" text="RÔLE" />
                     <ComboBox fx:id="roleCombo" promptText="Choisir un rôle" maxWidth="1.7976931348623157E308" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8;" />
                     <Label fx:id="roleError" styleClass="field-error" text="" visible="false" managed="false" />
                 </VBox>
             </HBox>
             
             <HBox alignment="CENTER_RIGHT">
                 <Button mnemonicParsing="false" onAction="#handleUpdateUser" styleClass="button-primary" style="-fx-background-radius: 20px; -fx-padding: 10 30;" text="✓ METTRE À JOUR" />
             </HBox>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>
