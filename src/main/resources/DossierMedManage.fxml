<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefWidth="600.0" prefHeight="750.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DossierMedManageController">
    <stylesheets>
        <URL value="@commande.css" />
    </stylesheets>

    <VBox alignment="CENTER">
        <VBox maxWidth="520" spacing="20" styleClass="form-card">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

            <VBox alignment="CENTER" spacing="5">
                <Label styleClass="page-title" style="-fx-font-size:26px;" text="Terminal de Surcharge Clinique" />
                <Label styleClass="page-subtitle" text="Modifier les données biologiques du patient." />
            </VBox>

            <Separator style="-fx-opacity: 0.1;" />

            <GridPane hgap="20" vgap="18">
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="PRÉNOM" />
                    <TextField fx:id="prenomField" styleClass="dark-field" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="NOM" />
                    <TextField fx:id="nomField" styleClass="dark-field" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label styleClass="field-label" text="TAILLE (cm)" />
                    <TextField fx:id="tailleField" styleClass="dark-field" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label styleClass="field-label" text="POIDS (kg)" />
                    <TextField fx:id="poidField" styleClass="dark-field" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label styleClass="field-label" text="GROUPE SANGUIN" />
                    <TextField fx:id="bloodTypeField" styleClass="dark-field" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label styleClass="field-label" text="TEMP. CORPORELLE (°C)" />
                    <TextField fx:id="tempField" styleClass="dark-field" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label styleClass="field-label" text="ÂGE" />
                    <TextField fx:id="ageField" styleClass="dark-field" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label styleClass="field-label" text="SEXE" />
                    <TextField fx:id="sexeField" styleClass="dark-field" />
                </VBox>
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="SOMETIMES" />
                    <RowConstraints vgrow="SOMETIMES" />
                    <RowConstraints vgrow="SOMETIMES" />
                    <RowConstraints vgrow="SOMETIMES" />
                </rowConstraints>
            </GridPane>

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="12">
                <Button maxWidth="Infinity" onAction="#handleUpdateFolder" styleClass="submit-button" text="Confirmer la mise à jour" />
                <Button maxWidth="Infinity" onAction="#handleDeleteFolder" styleClass="action-btn-delete" text="Supprimer le dossier" />
                <Button maxWidth="Infinity" onAction="#closeWindow" styleClass="cancel-button" text="Annuler les modifications" />
            </VBox>
        </VBox>
    </VBox>
</StackPane>