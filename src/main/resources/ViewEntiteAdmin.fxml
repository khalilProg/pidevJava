<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ViewEntiteAdmin">
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item, sidebar-item-active" text="🏥  Collectes" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="khalilboujemaa@gmail" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="DÉTAILS DE L'ENTITÉ" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Informations complètes sur le lieu de collecte." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15.0">
                <Button mnemonicParsing="false" text="← RETOUR" onAction="#handleRetour" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
                <Button mnemonicParsing="false" text="✏ MODIFIER" onAction="#handleNavigateModifier" styleClass="button-primary" style="-fx-background-radius: 20; -fx-padding: 8 20;" />
            </HBox>
         </HBox>
         
         <VBox styleClass="glass-card" spacing="30.0" maxWidth="800.0" style="-fx-padding: 40;">
             <HBox spacing="30.0" alignment="CENTER_LEFT">
                 <Label fx:id="iconLabel" text="🏥" style="-fx-background-color: rgba(230,57,57,0.1); -fx-text-fill: -primary; -fx-font-size: 40px; -fx-min-width: 100; -fx-min-height: 100; -fx-alignment: center; -fx-background-radius: 15; -fx-border-color: -primary; -fx-border-radius: 15; -fx-border-width: 1;" />
                 <VBox spacing="8.0" alignment="CENTER_LEFT">
                     <Label fx:id="nomLabel" text="Hôpital Central" style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 28px;" />
                     <HBox spacing="15.0" alignment="CENTER_LEFT">
                         <Label style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 3 8; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 10px;" text="ACTIF" />
                         <Label fx:id="villeLabel" text="📍 Tunis" style="-fx-text-fill: -muted; -fx-font-size: 14px;" />
                     </HBox>
                 </VBox>
             </HBox>
             
             <Region prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.05);" />
             
             <GridPane vgap="20.0" hgap="40.0">
                 <columnConstraints>
                     <ColumnConstraints minWidth="150" />
                     <ColumnConstraints hgrow="ALWAYS" />
                 </columnConstraints>
                 
                 <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5.0">
                     <Label text="ADRESSE" style="-fx-text-fill: -muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                     <Label fx:id="adresseLabel" text="123 Rue de la Liberté" style="-fx-text-fill: white; -fx-font-size: 15px;" wrapText="true" />
                 </VBox>
                 
                 <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5.0">
                     <Label text="TÉLÉPHONE" style="-fx-text-fill: -muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                     <Label fx:id="telephoneLabel" text="71 123 456" style="-fx-text-fill: -primary; -fx-font-size: 18px; -fx-font-weight: bold;" />
                 </VBox>
                 
                 <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="5.0">
                     <Label text="ID SYSTÈME" style="-fx-text-fill: -muted; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                     <Label fx:id="idLabel" text="#42" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-family: 'Monospaced';" />
                 </VBox>
             </GridPane>
         </VBox>
      </VBox>
   </center>
</BorderPane>
