<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="800.0" stylesheets="@styleFront.css" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.EntiteCollecteFrontController">
   <children>
      <Label layoutX="32.0" layoutY="28.0" text="Où faire un don ? (Entités de collecte)" styleClass="hero-title-main">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <TextField fx:id="txtRechercheFront" layoutX="32.0" layoutY="95.0" prefHeight="35.0" prefWidth="256.0" promptText="Rechercher une entité..." styleClass="text-field" />
      <Button fx:id="btnTrier" layoutX="320.0" layoutY="95.0" mnemonicParsing="false" onAction="#handleTrier" text="⬇ Trier de A - Z" styleClass="btn-outline"/>

      <ScrollPane fx:id="scrollPaneEntite" layoutX="32.0" layoutY="145.0" prefHeight="400.0" prefWidth="740.0" styleClass="scroll-pane">
         <content>
            <GridPane fx:id="gridEntites" hgap="10" vgap="10">
            </GridPane>
         </content>
      </ScrollPane>

      <HBox layoutX="32.0" layoutY="570.0" spacing="15.0">
         <children>
            <Button fx:id="btnAjouter" mnemonicParsing="false" onAction="#handleAjouter" text="+ Ajouter" styleClass="btn-primary-modern" />
            <Button fx:id="btnModifier" mnemonicParsing="false" onAction="#handleModifier" text="✏ Modifier" styleClass="btn-outline" />
            <Button fx:id="btnSupprimer" mnemonicParsing="false" onAction="#handleSupprimer" text="🗑 Supprimer" styleClass="btn-outline" />
         </children>
      </HBox>
   </children>
</AnchorPane>
