<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DonationListController">
    <stylesheets>
        <URL value="@style.css" /> <!-- Change to if you named it that -->
    </stylesheets>

    <StackPane styleClass="main-container" />

    <HBox spacing="0">
        <fx:include fx:id="sidebar" source="admin_sidebar.fxml" />

        <!-- Right Core View Container -->
        <VBox styleClass="content-area" HBox.hgrow="ALWAYS" spacing="30.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label styleClass="breadcrumb-label" text="ADMIN / LOGISTIQUE / INVENTAIRE" />
                    <Label styleClass="page-title" text="Intelligence d'Inventaire" />
                    <Label styleClass="page-subtitle" text="Suivi des flux de dons et stabilité de la chaîne d'approvisionnement." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="searchField" prefWidth="350" promptText="Rechercher une classification..." styleClass="dark-field" />
            </HBox>

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">

                <!-- The Logs Datagrid Area -->
                <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                    <Label styleClass="form-title" text="JOURNAL DES TRANSACTIONS EN DIRECT" />
                    <TableView fx:id="donationTable" styleClass="dark-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colClientName" prefWidth="180" text="NOM COMPLET DU DONNEUR" />
                            <TableColumn fx:id="colEntityName" prefWidth="150" text="CENTRE D'EXTRACTION" />
                            <TableColumn fx:id="colType" prefWidth="150" text="CLASSIFICATION" />
                            <TableColumn fx:id="colQte" prefWidth="100" text="RENDEMENT (ML)" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- Operations Sidebar Pane -->
                <VBox prefWidth="420.0" minWidth="420.0" styleClass="form-card" spacing="25.0">
                    <padding><Insets bottom="35.0" left="35.0" right="35.0" top="35.0" /></padding>

                    <VBox spacing="5">
                        <Label styleClass="form-section-title" text="GESTION DES DONNÉES" />
                        <Label styleClass="admin-card-copy" text="Utilisez les menus déroulants ci-dessous pour ajouter ou modifier des enregistrements en toute sécurité." wrapText="true" />
                    </VBox>

                    <!-- 🔥 UPDATED FIELDS: COMBOBOX (DROPDOWNS) INSTEAD OF ID TEXT BOXES! -->
                    <VBox spacing="18">
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="DOSSIER DONNEUR / PATIENT" />
                            <ComboBox fx:id="clientBox" styleClass="combo-box" promptText="Sélectionner le Patient..." maxWidth="Infinity" />
                        </VBox>
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="CENTRE D'ORIGINE / DESTINATION" />
                            <ComboBox fx:id="entityBox" styleClass="combo-box" promptText="Sélectionner le Centre..." maxWidth="Infinity" />
                        </VBox>
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="CATÉGORIE CLINIQUE" />
                            <TextField fx:id="typeField" styleClass="dark-field" promptText="Ex: Sang complet / Plasma" />
                        </VBox>
                        <VBox spacing="8">
                            <Label styleClass="field-label" text="EXTRAIT TOTAL (ML)" />
                            <TextField fx:id="qteField" styleClass="dark-field" promptText="Ex: 450.0" />
                        </VBox>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <VBox spacing="15">
                        <Button onAction="#handleAddDonation" maxWidth="Infinity" styleClass="submit-button" text="Exécuter l'Ajout" />
                        <HBox spacing="15">
                            <Button onAction="#handleUpdateDonation" maxWidth="Infinity" styleClass="cancel-button" text="Modifier" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleDeleteDonation" maxWidth="Infinity" styleClass="action-btn-delete" text="Supprimer" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                </VBox>

            </HBox>
        </VBox>
    </HBox>
</StackPane>