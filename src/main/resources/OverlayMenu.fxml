<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

    <HBox fx:id="menuOverlay" alignment="CENTER_RIGHT" managed="false" visible="false" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
        <Region fx:id="menuBackdrop" styleClass="menu-backdrop" HBox.hgrow="ALWAYS" />
        <VBox fx:id="menuPanel" alignment="TOP_LEFT" prefWidth="380.0" spacing="15.0" styleClass="menu-panel">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="menuFermerBtn" mnemonicParsing="false" styleClass="submit-button" text="FERMER" />
                </HBox>
                <Region prefHeight="20.0" />
                <Button fx:id="menuAccueilBtn" mnemonicParsing="false" styleClass="menu-link" text="ACCUEIL" />
                <Button fx:id="menuDemandesBtn" mnemonicParsing="false" styleClass="menu-link" text="DEMANDES" />
                <Button fx:id="menuTransfertsBtn" mnemonicParsing="false" styleClass="menu-link" text="TRANSFERTS" />
                <Button fx:id="menuCampagnesBtn" mnemonicParsing="false" styleClass="menu-link" text="CAMPAGNES" />
                <Button fx:id="menuEntitesBtn" mnemonicParsing="false" styleClass="menu-link" text="ENTITÉS DE COLLECTE" />
                <Button fx:id="menuHistoriqueBtn" mnemonicParsing="false" styleClass="menu-link" text="HISTORIQUE RDV" />
                <Button fx:id="menuCommandesBtn" mnemonicParsing="false" styleClass="menu-link" text="COMMANDES" />
                <Button fx:id="menuDonsBtn" mnemonicParsing="false" styleClass="menu-link" text="MES DONS" />
                <Button fx:id="menuDossierMedBtn" mnemonicParsing="false" styleClass="menu-link" text="DOSSIER MEDICAL" />
                <Button fx:id="menuProfilBtn" mnemonicParsing="false" styleClass="menu-link" text="MON PROFIL" />
                <Region VBox.vgrow="ALWAYS" />
                <VBox spacing="15.0">
                    <Label fx:id="sessionEmailLabel" styleClass="menu-session" text="Session: utilisateur@email.com" />
                    <Button fx:id="menuLogoutBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="submit-button" text="Deconnexion" />
                </VBox>
            </children>
        </VBox>
    </HBox>
