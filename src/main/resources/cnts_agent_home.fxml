<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styleFront.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.CntsAgentHomeController">
   <children>
      <VBox styleClass="main-content">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" styleClass="header-bar">
               <children>
                  <Label style="-fx-text-fill: #e63939; -fx-font-size: 24px;" text="BL">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </Label>
                  <Label styleClass="logo-text" text="BLOODLINK" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="userNameBtn" mnemonicParsing="false" style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-weight: 800; -fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 13px;" text="Agent CNTS">
                     <HBox.margin>
                        <Insets right="15.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="menuToggleBtn" mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="menu-toggle" text="MENU" />
               </children>
            </HBox>

            <VBox styleClass="hero-section-alt">
               <children>
                  <Label styleClass="hero-label-small" text="CNTS DESK" />
                  <Label styleClass="hero-title-large" text="Campagnes de Collecte" />
                  <Label styleClass="hero-subtitle-alt" text="Vue CNTS pour suivre, filtrer et consulter les campagnes actives" />
               </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10 50 10 50;" styleClass="hero-section-alt">
               <children>
                  <TextField fx:id="txtRechercheFront" prefHeight="40.0" prefWidth="250.0" promptText="Rechercher..." styleClass="text-field" />
                  <DatePicker fx:id="datePickerFilter" prefHeight="40.0" prefWidth="180.0" promptText="Filtrer par date" styleClass="dark-datepicker" />
                  <Button fx:id="btnTrier" mnemonicParsing="false" onAction="#handleTrier" style="-fx-padding: 8 15;" styleClass="btn-outline" text="Sort A-Z" />
                  <Button fx:id="btnTrierDate" mnemonicParsing="false" onAction="#handleTrierDate" style="-fx-padding: 8 15;" styleClass="btn-outline" text="Date" />
                  <Button mnemonicParsing="false" onAction="#handleReset" style="-fx-padding: 8 15;" styleClass="btn-outline-red" text="Reset" />
                  <Button mnemonicParsing="false" onAction="#goToCalendar" style="-fx-padding: 8 15;" styleClass="btn-outline" text="Vue Calendrier" />
               </children>
            </HBox>

            <AnchorPane VBox.vgrow="ALWAYS">
               <children>
                  <VBox fx:id="vboxEmptyState" visible="false" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0" styleClass="empty-state-vbox">
                     <children>
                        <Label style="-fx-font-size: 50;" text="..." />
                        <Label styleClass="empty-state-text" text="Aucune campagne active" />
                        <Label styleClass="empty-state-subtext" text="Revenez plus tard pour voir les nouvelles campagnes CNTS." />
                     </children>
                  </VBox>

                  <ScrollPane fx:id="scrollPaneCampagnes" fitToWidth="true" styleClass="scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <content>
                        <GridPane fx:id="gridCampagnes" hgap="30.0" styleClass="grid-container" vgap="30.0" />
                     </content>
                  </ScrollPane>
               </children>
            </AnchorPane>
         </children>
      </VBox>

      <HBox fx:id="menuOverlay" alignment="CENTER_RIGHT" managed="false" visible="false">
         <children>
            <Region onMouseClicked="#handleMenuClose" style="-fx-background-color: rgba(0,0,0,0.6);" HBox.hgrow="ALWAYS" />
            <VBox fx:id="menuPanel" alignment="TOP_LEFT" prefWidth="380.0" spacing="15.0" styleClass="menu-panel">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleMenuToggle" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 800; -fx-cursor: hand;" text="FERMER" />
                     </children>
                  </HBox>
                  <Region prefHeight="20.0" />
                  <Button mnemonicParsing="false" onAction="#goToCampagnes" style="-fx-text-fill: -primary;" styleClass="menu-link" text="CAMPAGNES" />
                  <Button mnemonicParsing="false" styleClass="menu-link" text="PROFIL" />
                  <Region VBox.vgrow="ALWAYS" />
                  <VBox spacing="15.0">
                     <children>
                        <Label fx:id="sessionEmailLabel" style="-fx-text-fill: -muted; -fx-font-size: 13px;" text="CNTS Session" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 14px; -fx-padding: 12 20; -fx-background-radius: 20; -fx-cursor: hand;" text="DECONNEXION" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</StackPane>
