<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueDemandeController" spacing="25"
      style="-fx-background-color: #0d0d0d; -fx-padding: 40 50;">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" styleClass="page-subtitle" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <SVGPath content="M 12 2 C 12 2 4 10 4 16 C 4 20.418 7.582 24 12 24 C 16.418 24 20 20.418 20 16 C 20 10 12 2 12 2 Z" fill="#E53935" scaleX="1.2" scaleY="1.2"/>
                <Label text="Mes Demandes" styleClass="page-title"/>
            </HBox>
            <Label text="Consultez et gérez vos demandes de sang." styleClass="page-subtitle"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Button text="📦 Mon Stock" styleClass="btn-secondary" onAction="#showMyStock"/>
            <Button fx:id="predictButton" text="🤖 Prédiction IA" styleClass="btn-ai" onAction="#runAIPrediction"/>
            <Button text="📄 Exporter PDF" styleClass="btn-secondary" onAction="#exportPDF"/>
            <Button text="✚ Nouvelle demande" styleClass="btn-primary" onAction="#openNewDemande"/>
        </HBox>
    </HBox>

    <!-- Filters Section -->
    <HBox styleClass="filter-bar" spacing="20" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Type sanguin, statut..." styleClass="search-field" prefWidth="400"/>
        <ComboBox fx:id="urgencyFilter" promptText="Toutes urgences" styleClass="dark-combo-box" prefWidth="200" />
        <ComboBox fx:id="statusFilter" promptText="Tous les statuts" styleClass="dark-combo-box" prefWidth="200" />
    </HBox>

    <!-- Content Empty State -->
    <VBox fx:id="emptyStateContainer" alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS" visible="false" managed="false" style="-fx-background-color: #111111; -fx-border-color: #222222; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 50;">
        <StackPane style="-fx-background-color: #2a1111; -fx-background-radius: 30; -fx-padding: 20;">
            <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z" fill="#E53935" scaleX="1.5" scaleY="1.5"/>
        </StackPane>
        <Label text="Aucune demande" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Vous n'avez pas encore de demande ou aucune ne correspond à vos filtres." style="-fx-text-fill: #888888;"/>
        <Button text="Créer ma première demande" styleClass="btn-primary" onAction="#openNewDemande" style="-fx-padding: 10 30;"/>
    </VBox>

    <!-- Table Section -->
    <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
        <HBox alignment="BOTTOM_LEFT">
            <Label text="LISTE DES DEMANDES" style="-fx-text-fill: #777777; -fx-font-weight: bold; -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="9 commande(s)" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS">
            <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;" />
        </ScrollPane>
    </VBox>

</VBox>
