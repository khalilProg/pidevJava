<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@commande.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueDemandeController" spacing="25"
      styleClass="main-content" style="-fx-padding: 40 50;">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" styleClass="breadcrumb-label" />
            <Label text="Mes Demandes" styleClass="admin-page-title" />
            <Label text="Consultez et gérez vos demandes de sang." styleClass="page-subtitle" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Button text="Prédiction IA" styleClass="cancel-button" onAction="#runAIPrediction"/>
            <Button text="Exporter PDF" styleClass="cancel-button" onAction="#exportPDF"/>
            <Button text="+ Nouvelle demande" styleClass="submit-button" onAction="#openNewDemande"/>
        </HBox>
    </HBox>

    <!-- Filters Section -->
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="form-card" style="-fx-padding: 15 20;">
        <TextField promptText="Type sanguin, statut..." styleClass="dark-field" prefWidth="400"/>
        <ComboBox promptText="Toutes urgences" styleClass="dark-combo" prefWidth="200" />
        <ComboBox promptText="Tous les statuts" styleClass="dark-combo" prefWidth="200" />
    </HBox>

    <!-- Content Empty State -->
    <VBox fx:id="emptyStateContainer" alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS" visible="false" managed="false" styleClass="form-card">
        <Label text="Aucune demande" styleClass="admin-page-title" />
        <Label text="Vous n'avez pas encore de demande ou aucune ne correspond à vos filtres." styleClass="page-subtitle" />
        <Button text="Créer ma première demande" styleClass="submit-button" onAction="#openNewDemande" style="-fx-padding: 10 30;"/>
    </VBox>

    <!-- Table Section -->
    <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
        <HBox alignment="BOTTOM_LEFT">
            <Label text="LISTE DES DEMANDES" styleClass="breadcrumb-label" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="9 commande(s)" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="edge-to-edge-scroll" VBox.vgrow="ALWAYS">
            <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;" />
        </ScrollPane>
    </VBox>

</VBox>
