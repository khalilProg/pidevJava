<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueDemandeController" spacing="30"
      styleClass="main-content agent-page agent-demandes-page">

    <HBox alignment="CENTER_LEFT" spacing="24">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" styleClass="agent-kicker"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <SVGPath content="M 12 2 C 12 2 4 10 4 16 C 4 20.418 7.582 24 12 24 C 16.418 24 20 20.418 20 16 C 20 10 12 2 12 2 Z" fill="#E53935" scaleX="1.2" scaleY="1.2"/>
                <Label text="Mes demandes" styleClass="agent-title"/>
            </HBox>
            <Label text="Consultez et gerez vos demandes de sang." styleClass="agent-subtitle"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="12">
            <HBox alignment="CENTER" spacing="7">
                <Button text="📦 Mon stock" styleClass="btn-secondary" onAction="#showMyStock"/>
                <SVGPath fx:id="stockAlertIcon" content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="#E53935" visible="false" managed="false"/>
            </HBox>
            <Button fx:id="predictButton" text="🤖 Prediction IA" styleClass="btn-ai" onAction="#runAIPrediction"/>
            <Button text="📄 Exporter PDF" styleClass="btn-secondary" onAction="#exportPDF"/>
            <Button text="📋 Voir commandes" styleClass="btn-secondary" onAction="#toggleCommandes"/>
            <Button text="+ Nouvelle demande" styleClass="btn-primary" onAction="#openNewDemande"/>
        </HBox>
    </HBox>

    <VBox styleClass="glass-card" spacing="20" VBox.vgrow="ALWAYS">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="agent-search-box" prefWidth="400">
                <FontIcon iconLiteral="fas-search" iconSize="13" styleClass="agent-search-icon"/>
                <TextField fx:id="searchField" promptText="Type sanguin, statut..." styleClass="transparent-input" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="urgencyFilter" promptText="Toutes urgences" styleClass="filter-btn" prefWidth="200"/>
            <ComboBox fx:id="statusFilter" promptText="Tous les statuts" styleClass="filter-btn" prefWidth="200"/>
        </HBox>

        <VBox fx:id="emptyStateContainer" alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS" visible="false" managed="false" styleClass="agent-empty-state">
            <StackPane styleClass="agent-empty-icon">
                <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z" fill="#E53935" scaleX="1.5" scaleY="1.5"/>
            </StackPane>
            <Label text="Aucune demande" styleClass="agent-empty-title"/>
            <Label text="Vous n'avez pas encore de demande ou aucune ne correspond a vos filtres." styleClass="agent-empty-copy"/>
            <Button text="Creer ma premiere demande" styleClass="btn-primary" onAction="#openNewDemande"/>
        </VBox>

        <VBox fx:id="paneCommandes" VBox.vgrow="ALWAYS" spacing="10" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" styleClass="agent-section-header">
                <Label text="COMMANDES RECUES" styleClass="agent-section-title" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCmdCount" text="0 commande(s)" styleClass="agent-count-label"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS" minHeight="400">
                <VBox fx:id="commandCardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;"/>
            </ScrollPane>
        </VBox>

        <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" styleClass="agent-section-header">
                <Label text="LISTE DES DEMANDES" styleClass="agent-section-title" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblDemandeCount" text="0 demande(s)" styleClass="agent-count-label"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS">
                <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;"/>
            </ScrollPane>
        </VBox>
    </VBox>

</VBox>
