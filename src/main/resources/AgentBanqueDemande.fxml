<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueDemandeController" spacing="40"
      styleClass="main-content" style="-fx-padding: 40 50;">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <SVGPath content="M 12 2 C 12 2 4 10 4 16 C 4 20.418 7.582 24 12 24 C 16.418 24 20 20.418 20 16 C 20 10 12 2 12 2 Z" fill="#E53935" scaleX="1.2" scaleY="1.2"/>
                <Label text="Mes Demandes" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;"/>
            </HBox>
            <Label text="Consultez et gérez vos demandes de sang." style="-fx-text-fill: #888888; -fx-font-size: 14px;"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="12">
            <HBox alignment="CENTER" spacing="5">
                <Button text="📦 Mon Stock" styleClass="btn-secondary" onAction="#showMyStock"/>
                <SVGPath fx:id="stockAlertIcon" content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="#E53935" visible="false" managed="false"/>
            </HBox>
            <Button fx:id="predictButton" text="🤖 Prédiction IA" styleClass="btn-ai" onAction="#runAIPrediction"/>
            <Button text="📄 Exporter PDF" styleClass="btn-secondary" onAction="#exportPDF"/>
            <Button text="📦 Voir Commandes" styleClass="btn-secondary" onAction="#toggleCommandes"/>
            <Button text="✚ Nouvelle demande" styleClass="btn-primary" onAction="#openNewDemande"/>
        </HBox>
    </HBox>

    <!-- Main Glass Card Container -->
    <VBox styleClass="glass-card" spacing="20" VBox.vgrow="ALWAYS">

        <!-- Filters Section -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-field" prefWidth="400" style="-fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10;">
                <Label text="🔍" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
                <TextField fx:id="searchField" promptText="Type sanguin, statut..." styleClass="transparent-input" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="urgencyFilter" promptText="Toutes urgences" styleClass="filter-btn" prefWidth="200" />
            <ComboBox fx:id="statusFilter" promptText="Tous les statuts" styleClass="filter-btn" prefWidth="200" />
        </HBox>

        <!-- Content Empty State -->
        <VBox fx:id="emptyStateContainer" alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS" visible="false" managed="false" style="-fx-padding: 50;">
            <StackPane style="-fx-background-color: rgba(231, 76, 60, 0.08); -fx-background-radius: 30; -fx-padding: 20;">
                <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z" fill="#E53935" scaleX="1.5" scaleY="1.5"/>
            </StackPane>
            <Label text="Aucune demande" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Vous n'avez pas encore de demande ou aucune ne correspond à vos filtres." style="-fx-text-fill: #888888;"/>
            <Button text="Créer ma première demande" styleClass="btn-primary" onAction="#openNewDemande" style="-fx-padding: 10 30;"/>
        </VBox>

        <!-- Commandes Section (Hidden by default) -->
        <VBox fx:id="paneCommandes" VBox.vgrow="ALWAYS" spacing="10" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" style="-fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 10 0;">
                <Label text="COMMANDES REÇUES" style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-weight: 800; -fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblCmdCount" text="0 commande(s)" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS" minHeight="400">
                <VBox fx:id="commandCardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;" />
            </ScrollPane>
        </VBox>

        <!-- Table Section -->
        <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" style="-fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 10 0;">
                <Label text="LISTE DES DEMANDES" style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-weight: 800; -fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblDemandeCount" text="0 demande(s)" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="dark-scroll-pane" VBox.vgrow="ALWAYS">
                <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding: 5 15 20 0;" />
            </ScrollPane>
        </VBox>
    </VBox>

</VBox>
