<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-container" stylesheets="@commande.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AdminAfficherCommandesController">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <left>
        <VBox styleClass="sidebar">
            <!-- Brand -->
            <HBox styleClass="sidebar-brand" alignment="CENTER_LEFT" spacing="8">
                <Region styleClass="logo-icon"/>
                <Label text="BLOODLINK" styleClass="sidebar-brand-text"/>
                <Label text="ADMIN" styleClass="sidebar-admin-badge"/>
            </HBox>

            <!-- Section Label -->
            <Label text="GESTION" styleClass="sidebar-section-label"/>

            <!-- Navigation Items -->
            <VBox styleClass="sidebar-nav-list" spacing="2">
                <Button text="📊  Dashboard" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="👥  Utilisateurs" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="📦  Commandes" styleClass="sidebar-nav-item-active" maxWidth="1.7976931348623157E308" onAction="#goToCommandes"/>
                <Button text="🏢  Stocks" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308" onAction="#goToStocks"/>
                <Button text="📋  Demandes" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="🔄  Transferts" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="❓  Questionnaires" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="📅  Rendez-vous" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="📢  Campagnes" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="🏥  Collectes" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="💉  Dons" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
                <Button text="📁  Dossiers" styleClass="sidebar-nav-item" maxWidth="1.7976931348623157E308"/>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- User Section -->
            <VBox styleClass="sidebar-user-section" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="sidebar-user-avatar">
                        <Region styleClass="logo-icon"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="admin@bloodlink.tn" styleClass="sidebar-user-email"/>
                        <Label text="Administrateur" styleClass="sidebar-user-role"/>
                    </VBox>
                </HBox>
                <Button text="⏻  Déconnexion" styleClass="sidebar-disconnect-btn" maxWidth="1.7976931348623157E308"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #121212;">
            <padding>
                <Insets bottom="32" left="32" right="32" top="28"/>
            </padding>

            <!-- Page Header -->
            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="page-title" text="COMMANDES DE SANG"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label styleClass="page-subtitle" text="Gérez les demandes de sang et suivez leur statut de validation."/>
            </VBox>

            <!-- Search + Filters Bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="tfSearch" prefWidth="300" promptText="🔍  Rechercher par référence, sang..." styleClass="dark-field" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbStatutFiltre" prefWidth="150" promptText="Tous statuts" styleClass="dark-combo"/>
                <ComboBox fx:id="cbPrioriteFiltre" prefWidth="150" promptText="Priorités" styleClass="dark-combo"/>
            </HBox>

            <!-- Table -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="lblCount" style="-fx-text-fill: #777777; -fx-font-size: 11px; -fx-font-weight: bold;" text="0 commande(s)"/>
                </HBox>

                <TableView fx:id="tableCommandes" styleClass="dark-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colReference" prefWidth="130" text="RÉFÉRENCE"/>
                        <TableColumn fx:id="colTypeSang" prefWidth="120" text="TYPE SANG"/>
                        <TableColumn fx:id="colQuantite" prefWidth="120" text="QUANTITÉ"/>
                        <TableColumn fx:id="colPriorite" prefWidth="130" text="PRIORITÉ"/>
                        <TableColumn fx:id="colStatut" prefWidth="160" text="STATUT"/>
                        <TableColumn fx:id="colActions" prefWidth="200" text="ACTIONS" style="-fx-alignment: center-right;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
