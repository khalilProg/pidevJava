<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Line?>

<VBox stylesheets="@agent_banque.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueViewTransfertController" spacing="30"
      style="-fx-background-color: #0d0d0d; -fx-padding: 40 50;">

    <Button text="← Retour aux transferts" style="-fx-text-fill: #b3b3b3; -fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" onAction="#goBack"/>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTitle" text="Transfert #1" styleClass="page-title"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z" fill="#E53935" scaleX="0.8" scaleY="0.8"/>
                <Label fx:id="lblCreatedAt" text="Enregistré le 12/02/2026 à 15:03" style="-fx-text-fill: #b3b3b3; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
        
        <Label fx:id="lblStatusTop" text="✔ Transfert Reçu" style="-fx-background-color: rgba(40, 167, 69, 0.1); -fx-border-color: #28a745; -fx-border-radius: 20; -fx-text-fill: #28a745; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-font-size: 14px;"/>
    </HBox>

    <VBox spacing="35" style="-fx-background-color: #111111; -fx-border-color: #222222; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 40 50;" VBox.vgrow="ALWAYS">
        
        <!-- Graphical Flow Path -->
        <HBox alignment="CENTER" spacing="0">
            <!-- Origine Box -->
            <VBox alignment="CENTER" spacing="10" prefWidth="280" style="-fx-background-color: #0A0A0A; -fx-border-color: #333333; -fx-border-style: dashed; -fx-border-radius: 10; -fx-padding: 25;">
                <HBox alignment="CENTER" spacing="8">
                    <SVGPath content="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" fill="#E53935" scaleX="0.8" scaleY="0.8"/>
                    <Label text="ORIGINE" style="-fx-text-fill: #aaaaaa; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                </HBox>
                <Label fx:id="lblOrigine" text="CNTS" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="lblOrigineId" text="ID: 32" style="-fx-background-color: #222222; -fx-text-fill: #777777; -fx-padding: 4 12; -fx-background-radius: 12; -fx-font-size: 11px;"/>
            </VBox>

            <!-- Arrow and Quantity -->
            <StackPane HBox.hgrow="ALWAYS" maxWidth="250">
                <Line startX="0" endX="200" style="-fx-stroke: #444444; -fx-stroke-width: 2; -fx-stroke-dash-array: 5 5;"/>
                <VBox alignment="CENTER">
                    <Label fx:id="lblFlowQuantite" text="🩸 12" style="-fx-background-color: #222222; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 5 20; -fx-background-radius: 20;"/>
                    <SVGPath content="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" fill="#E53935" scaleX="0.7" scaleY="0.7"/>
                </VBox>
            </StackPane>

            <!-- Destination Box -->
            <VBox alignment="CENTER" spacing="10" prefWidth="280" style="-fx-background-color: #0A0A0A; -fx-border-color: #333333; -fx-border-style: dashed; -fx-border-radius: 10; -fx-padding: 25;">
                <HBox alignment="CENTER" spacing="8">
                    <SVGPath content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#E53935" scaleX="0.8" scaleY="0.8"/>
                    <Label text="DESTINATION" style="-fx-text-fill: #aaaaaa; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                </HBox>
                <Label fx:id="lblDestination" text="Mahmoud El Matri Hospital" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" textAlignment="CENTER" wrapText="true"/>
                <Label fx:id="lblDestinationId" text="ID: 10" style="-fx-background-color: #222222; -fx-text-fill: #777777; -fx-padding: 4 12; -fx-background-radius: 12; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <!-- Information Cards -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <!-- Demande Liee -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="DEMANDE LIÉE" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblDemandeLiee" text="DEM-2" style="-fx-background-color: #222222; -fx-text-fill: #bbbbbb; -fx-padding: 8 16; -fx-background-radius: 20; -fx-font-size: 13px; -fx-cursor: hand;" />
            </VBox>

            <!-- Lot / Stock -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="LOT / STOCK" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblBloodType" text="AB+" style="-fx-background-color: transparent; -fx-border-color: #E53935; -fx-border-radius: 20; -fx-text-fill: #E53935; -fx-padding: 4 15; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Date Envoi -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="DATE D'ENVOI" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblDateEnvoi" text="12/02/2026" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Date Reception -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #0d0d0d; -fx-border-color: #222222; -fx-border-radius: 8; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <SVGPath content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z" fill="#555555" scaleX="0.8" scaleY="0.8"/>
                    <Label text="DATE DE RÉCEPTION" style="-fx-text-fill: #777777; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblDateReception" text="12/02/2026" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

    </VBox>
</VBox>
