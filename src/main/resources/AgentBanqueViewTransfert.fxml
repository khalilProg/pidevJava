<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Line?>

<VBox stylesheets="@commande.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueViewTransfertController" spacing="30"
      styleClass="main-content" style="-fx-padding: 40 50;">

    <Button text="← Retour aux transferts" styleClass="retour-button" onAction="#goBack"/>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTitle" text="Transfert #1" styleClass="admin-page-title"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="lblCreatedAt" text="Enregistré le 12/02/2026 à 15:03" styleClass="page-subtitle"/>
            </HBox>
        </VBox>

        <Label fx:id="lblStatusTop" text="✔ Transfert Reçu" style="-fx-background-color: rgba(40, 167, 69, 0.1); -fx-border-color: #28a745; -fx-border-radius: 20; -fx-text-fill: #28a745; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-font-size: 14px;"/>
    </HBox>

    <VBox spacing="35" styleClass="form-card" VBox.vgrow="ALWAYS">

        <!-- Graphical Flow Path -->
        <HBox alignment="CENTER" spacing="0">
            <!-- Origine Box -->
            <VBox alignment="CENTER" spacing="10" prefWidth="280" styleClass="glass-card" style="-fx-padding: 25;">
                <Label text="ORIGINE" styleClass="field-label"/>
                <Label fx:id="lblOrigine" text="CNTS" styleClass="card-title" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="lblOrigineId" text="ID: 32" styleClass="card-subtitle" style="-fx-padding: 4 12; -fx-font-size: 11px;"/>
            </VBox>

            <!-- Arrow and Quantity -->
            <StackPane HBox.hgrow="ALWAYS" maxWidth="250">
                <Line startX="0" endX="200" style="-fx-stroke: rgba(255,255,255,0.15); -fx-stroke-width: 2; -fx-stroke-dash-array: 5 5;"/>
                <VBox alignment="CENTER">
                    <Label fx:id="lblFlowQuantite" text="12" styleClass="card-title" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 5 20;"/>
                    <Label text="→" style="-fx-text-fill: #e74c3c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>
            </StackPane>

            <!-- Destination Box -->
            <VBox alignment="CENTER" spacing="10" prefWidth="280" styleClass="glass-card" style="-fx-padding: 25;">
                <Label text="DESTINATION" styleClass="field-label"/>
                <Label fx:id="lblDestination" text="Mahmoud El Matri Hospital" styleClass="card-title" style="-fx-font-size: 16px; -fx-font-weight: bold;" textAlignment="CENTER" wrapText="true"/>
                <Label fx:id="lblDestinationId" text="ID: 10" styleClass="card-subtitle" style="-fx-padding: 4 12; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <!-- Information Cards -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <!-- Demande Liee -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="DEMANDE LIÉE" styleClass="field-label"/>
                <Label fx:id="lblDemandeLiee" text="DEM-2" styleClass="card-title" style="-fx-padding: 8 16; -fx-font-size: 13px; -fx-cursor: hand;" />
            </VBox>

            <!-- Lot / Stock -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="LOT / STOCK" styleClass="field-label"/>
                <Label fx:id="lblBloodType" text="AB+" style="-fx-background-color: transparent; -fx-border-color: #e74c3c; -fx-border-radius: 20; -fx-text-fill: #e74c3c; -fx-padding: 4 15; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Date Envoi -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="DATE D'ENVOI" styleClass="field-label"/>
                <Label fx:id="lblDateEnvoi" text="12/02/2026" styleClass="card-title" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Date Reception -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="DATE DE RÉCEPTION" styleClass="field-label"/>
                <Label fx:id="lblDateReception" text="12/02/2026" styleClass="card-title" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

    </VBox>
</VBox>
