<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<HBox stylesheets="@commande.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.BaseFront"
      spacing="0" alignment="CENTER_LEFT" styleClass="navbar-container"
      prefHeight="85" prefWidth="1550"  >

    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-section" HBox.hgrow="NEVER">
        <padding>
            <Insets left="25" right="25"/>
        </padding>
        <Label text="BLOODLINK" styleClass="nav-logo-text"/>
    </HBox>

    <HBox alignment="CENTER" spacing="30" HBox.hgrow="ALWAYS" styleClass="nav-links-container">
        <Button fx:id="accueilNavBtn" text="Accueil" styleClass="nav-link" onAction="#goToAccueil"/>
        <Button fx:id="historiqueNavBtn" text="Historique" styleClass="nav-link" onAction="#goToHistorique"/>
        <Button fx:id="campagnesNavBtn" text="Campagnes" styleClass="nav-link" onAction="#goToCampagnes"/>
<!--        <Button text="Questionnaires" styleClass="nav-link" onAction="#goToQuestionnaires"/>-->
<!--        <Button text="Rendez vous" styleClass="nav-link" onAction="#goToRendezVous"/>-->
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="user-section">
        <padding>
            <Insets left="25" right="25"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="user-pill">
            <children>
                <StackPane styleClass="user-icon-container">
                    <Circle fill="#E63939" radius="13.0" />
                    <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                             fill="WHITE" scaleX="0.8" scaleY="0.8" />
                </StackPane>

                <Label fx:id="userNameLabel" text="Utilisateur" styleClass="user-name-label" />
            </children>
        </HBox>

    </HBox>
</HBox>
