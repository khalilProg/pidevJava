<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
                fx:controller="tn.esprit.controllers.BaseFront"
            prefHeight="400.0" prefWidth="600.0">

<children>
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #1c1c1c;" prefHeight="50" prefWidth="600">
        <Label text="BLOODLINK" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userLabel" text="User Name" style="-fx-text-fill: white;" />
        <Button text="MENU" style="-fx-background-color: transparent; -fx-text-fill: white;" />
    </HBox>
</children>
</AnchorPane>