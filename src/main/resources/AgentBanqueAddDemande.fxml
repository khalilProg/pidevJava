<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@commande.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueAddDemandeController" spacing="30"
      styleClass="main-content" style="-fx-padding: 40 50;">

    <Button text="← Retour aux demandes" styleClass="retour-button" onAction="#goBack"/>

    <VBox spacing="5">
        <Label text="Créer une Demande" styleClass="admin-page-title" />
        <Label text="Remplissez les informations ci-dessous pour soumettre votre demande de sang." styleClass="page-subtitle" />
    </VBox>

    <VBox spacing="25" styleClass="form-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
            <VBox>
                <Label text="FORMULAIRE DE DEMANDE" styleClass="form-title" />
                <Label text="Veuillez vérifier les informations avant de sauvegarder." styleClass="form-description" />
            </VBox>
        </HBox>

        <HBox spacing="30">
            <!-- Left Column -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <VBox spacing="4">
                    <Label text="BANQUE" styleClass="field-label" />
                    <ComboBox fx:id="comboBanque" promptText="Sélectionnez une banque" styleClass="dark-combo" maxWidth="Infinity" prefHeight="45"/>
                    <Label fx:id="errBanque" text="Ce champ est requis" styleClass="field-error" visible="false" managed="false"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="QUANTITÉ (UNITÉS)" styleClass="field-label" />
                    <TextField fx:id="txtQuantite" promptText="Quantité en unités" styleClass="dark-field" prefHeight="45"/>
                    <Label fx:id="errQuantite" text="Ce champ est requis" styleClass="field-error" visible="false" managed="false"/>
                </VBox>
            </VBox>

            <!-- Right Column -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <VBox spacing="4">
                    <Label text="TYPE DE SANG" styleClass="field-label" />
                    <ComboBox fx:id="comboType" promptText="Choisissez un type" styleClass="dark-combo" maxWidth="Infinity" prefHeight="45"/>
                    <Label fx:id="errType" text="Ce champ est requis" styleClass="field-error" visible="false" managed="false"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="URGENCE" styleClass="field-label" />
                    <ComboBox fx:id="comboUrgence" promptText="Sélectionnez" styleClass="dark-combo" maxWidth="Infinity" prefHeight="45"/>
                    <Label fx:id="errUrgence" text="Ce champ est requis" styleClass="field-error" visible="false" managed="false"/>
                </VBox>
            </VBox>
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 30 0 0 0;">
            <Button text="ENVOYER LA DEMANDE" styleClass="submit-button" style="-fx-padding: 12 30;" onAction="#handleAddDemande"/>
        </HBox>
    </VBox>
</VBox>
