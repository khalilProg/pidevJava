<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DossierMedListController">
    <stylesheets>
        <URL value="@commande.css" />
    </stylesheets>

    <StackPane styleClass="main-container" />

    <HBox spacing="0">
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
            </padding>

            <VBox spacing="10.0" styleClass="sidebar-brand">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle fill="#e63939" radius="6.0" />
                    <Label styleClass="sidebar-brand-text" text="BLOODLINK" />
                </HBox>
                <Label styleClass="sidebar-admin-badge" text="INTELLIGENT SYSTEMS" />
            </VBox>

            <Region prefHeight="60.0" />

            <VBox spacing="10.0" styleClass="sidebar-nav-list">
                <Label styleClass="sidebar-section-label" text="ADMINISTRATION" />
                <Button onAction="#goToDashboard" styleClass="sidebar-nav-item" text="📊 Master Dashboard" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button styleClass="sidebar-nav-item-active" text="🩺 Medical Folders" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button onAction="#goToDonationLogs" styleClass="sidebar-nav-item" text="🩸 Donation Logs" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox styleClass="form-card" spacing="12">
                <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                <Label styleClass="welcome-badge-text" text="CLINICAL AI" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="4" fill="#2ecc71" />
                    <Label styleClass="admin-card-copy" text="Biometric Engine Active" />
                </HBox>
            </VBox>
        </VBox>

        <VBox styleClass="content-area" HBox.hgrow="ALWAYS" spacing="30.0">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label styleClass="breadcrumb-label" text="ADMIN / CLINICAL / REPOSITORY" />
                    <Label styleClass="page-title" text="Medical Intelligence" />
                    <Label styleClass="page-subtitle" text="Encrypted demographic parameters and AI eligibility predictions." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <TextField fx:id="searchField" prefWidth="350" promptText="Filter by patient name..." styleClass="dark-field" />
                    <Button onAction="#openAddMedicalView" styleClass="submit-button" text="+ New Enrollment" />
                </HBox>
            </HBox>

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <Label styleClass="form-title" text="ACTIVE CLINICAL PROFILES" />

                    <TableView fx:id="mainTable" styleClass="dark-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="50" text="FILE ID" />
                            <TableColumn fx:id="colPrenom" prefWidth="130" text="GIVEN NAME" />
                            <TableColumn fx:id="colNom" prefWidth="130" text="FAMILY NAME" />
                            <TableColumn fx:id="colAge" prefWidth="60" text="AGE" />
                            <TableColumn fx:id="colSexe" prefWidth="80" text="SEX" />
                            <TableColumn fx:id="colBlood" prefWidth="80" text="CLASS" />
                            <TableColumn fx:id="colTaille" prefWidth="90" text="VERT(cm)" />
                            <TableColumn fx:id="colTemp" prefWidth="90" text="TEMP(°C)" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#openManageMedicalView" styleClass="cancel-button" text="Edit Selected Profile" />
                    </HBox>
                </VBox>

                <VBox prefWidth="420.0" minWidth="420.0" spacing="25.0">
                    <VBox styleClass="form-card" spacing="20" style="-fx-border-color: rgba(231, 76, 60, 0.3);">
                        <padding>
                            <Insets bottom="30" left="30" right="30" top="30" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 24px;" text="🧠" />
                            <VBox>
                                <Label styleClass="form-section-title" text="AI HEMATOLOGY SCAN" />
                                <Label styleClass="admin-card-copy" text="Gemini Pro Vision Engine" />
                            </VBox>
                        </HBox>

                        <Separator style="-fx-opacity: 0.1;" />

                        <Label fx:id="aiResultLabel" styleClass="admin-card-copy"
                               style="-fx-font-size: 14px; -fx-text-fill: white; -fx-line-spacing: 6;"
                               text="Please select a genetic profile from the index to run eligibility diagnostics."
                               wrapText="true" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Button maxWidth="Infinity" onAction="#runAIPrediction" styleClass="submit-button" text="Initialize Analysis Sequence" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</StackPane>