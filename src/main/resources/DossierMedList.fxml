<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DossierMedListController">
    <stylesheets>
        <URL value="@commande.css" />
    </stylesheets>

    <StackPane styleClass="main-container" />

    <HBox spacing="0">
        <fx:include fx:id="sidebar" source="admin_sidebar.fxml" />

        <VBox styleClass="content-area" HBox.hgrow="ALWAYS" spacing="30.0">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label styleClass="breadcrumb-label" text="ADMIN / CLINIQUE / RÉFÉRENTIEL" />
                    <Label styleClass="page-title" text="Intelligence Médicale" />
                    <Label styleClass="page-subtitle" text="Paramètres démographiques et prédictions d'éligibilité IA." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <TextField fx:id="searchField" prefWidth="350" promptText="Filtrer par nom du patient..." styleClass="dark-field" />
                    <Button onAction="#openAddMedicalView" styleClass="submit-button" text="+ Nouvelle inscription" />
                </HBox>
            </HBox>

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <Label styleClass="form-title" text="PROFILS CLINIQUES ACTIFS" />

                    <TableView fx:id="mainTable" styleClass="dark-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="50" text="ID FICHIER" />
                            <TableColumn fx:id="colPrenom" prefWidth="130" text="PRÉNOM" />
                            <TableColumn fx:id="colNom" prefWidth="130" text="NOM" />
                            <TableColumn fx:id="colAge" prefWidth="60" text="ÂGE" />
                            <TableColumn fx:id="colSexe" prefWidth="80" text="SEXE" />
                            <TableColumn fx:id="colBlood" prefWidth="80" text="GROUPE" />
                            <TableColumn fx:id="colTaille" prefWidth="90" text="TAILLE(cm)" />
                            <TableColumn fx:id="colTemp" prefWidth="90" text="TEMP(°C)" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#openManageMedicalView" styleClass="cancel-button" text="Modifier le profil sélectionné" />
                    </HBox>
                </VBox>

                <VBox prefWidth="420.0" minWidth="420.0" spacing="25.0">
                    <VBox styleClass="form-card" spacing="20" style="-fx-border-color: rgba(231, 76, 60, 0.3);">
                        <padding>
                            <Insets bottom="30" left="30" right="30" top="30" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 24px;" text="🧠" />
                            <VBox>
                                <Label styleClass="form-section-title" text="SCAN HÉMATOLOGIQUE IA" />
                                <Label styleClass="admin-card-copy" text="Moteur Gemini Pro Vision" />
                            </VBox>
                        </HBox>

                        <Separator style="-fx-opacity: 0.1;" />

                        <Label fx:id="aiResultLabel" styleClass="admin-card-copy"
                               style="-fx-font-size: 14px; -fx-text-fill: white; -fx-line-spacing: 6;"
                               text="Veuillez sélectionner un profil génétique dans l'index pour lancer les diagnostics d'éligibilité."
                               wrapText="true" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Button maxWidth="Infinity" onAction="#runAIPrediction" styleClass="submit-button" text="Lancer l'analyse" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</StackPane>