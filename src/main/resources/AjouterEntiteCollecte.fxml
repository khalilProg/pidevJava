<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AjouterEntiteCollecteController">
   <children>
      <Label layoutX="37.0" layoutY="31.0" text="Ajouter une Entité">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <Label layoutX="37.0" layoutY="95.0" text="Nom :" />
      <TextField fx:id="txtNom" layoutX="130.0" layoutY="91.0" prefHeight="26.0" prefWidth="200.0" />
      
      <Label layoutX="37.0" layoutY="135.0" text="Téléphone :" />
      <TextField fx:id="txtTelephone" layoutX="130.0" layoutY="131.0" prefHeight="26.0" prefWidth="200.0" />
      
      <Label layoutX="37.0" layoutY="175.0" text="Type :" />
      <TextField fx:id="txtType" layoutX="130.0" layoutY="171.0" prefHeight="26.0" prefWidth="200.0" />
      
      <Label layoutX="37.0" layoutY="215.0" text="Adresse :" />
      <TextField fx:id="txtAdresse" layoutX="130.0" layoutY="211.0" prefHeight="26.0" prefWidth="200.0" />

      <Label layoutX="37.0" layoutY="255.0" text="Ville :" />
      <TextField fx:id="txtVille" layoutX="130.0" layoutY="251.0" prefHeight="26.0" prefWidth="200.0" />

      <Button fx:id="btnEnregistrer" layoutX="130.0" layoutY="324.0" mnemonicParsing="false" onAction="#handleEnregistrer" text="Enregistrer" />
      <Button fx:id="btnAnnuler" layoutX="273.0" layoutY="324.0" mnemonicParsing="false" onAction="#handleAnnuler" text="Annuler" />
   </children>
</AnchorPane>
