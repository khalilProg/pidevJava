<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.admin_dashboard">
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <!-- Logo -->
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         
         <!-- Category -->
         <Label styleClass="sidebar-category" text="GESTION" />
         
         <!-- Links -->
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item, sidebar-item-active" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         
         <!-- Profile & Logout -->
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="khalilboujemaa@gmail" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" spacing="30.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         
         <!-- Header Board -->
         <VBox styleClass="dashboard-header-bg" spacing="10.0">
             <Label style="-fx-text-fill: -primary; -fx-font-weight: 800; -fx-font-size: 12px; -fx-letter-spacing: 2px;" text="BLOODLINK ADMINISTRATION" />
             <Label style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: 900;" text="Bienvenue, Administrateur 👋" />
             <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Vous êtes sur le centre de contrôle de BloodLink. Gérez les stocks, suivez les&#10;commandes et supervisez la communauté des donneurs en toute simplicité." />
             <Region prefHeight="10.0" />
             <Button mnemonicParsing="false" styleClass="button-primary" style="-fx-background-radius: 20px;" text="👤 + NOUVEL UTILISATEUR" />
         </VBox>
         
         <!-- 3 KPI Cards -->
         <HBox spacing="20.0">
             <VBox prefWidth="320.0" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                 <HBox spacing="15.0" alignment="CENTER_LEFT">
                     <VBox styleClass="card-icon-container">
                         <Label text="👥" style="-fx-text-fill: -primary; -fx-font-size: 20px;" />
                     </VBox>
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 20px;" text="Utilisateurs" />
                 </HBox>
                 <Label style="-fx-text-fill: -muted; -fx-font-size: 12px; -fx-wrap-text: true;" text="Gérez les comptes, les rôles et accédez aux profils détaillés des donneurs et banques." />
                 <Region VBox.vgrow="ALWAYS" minHeight="20.0" />
                 <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="card-btn-outline" text="Ouvrir la liste" />
             </VBox>
             
             <VBox prefWidth="320.0" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                 <HBox spacing="15.0" alignment="CENTER_LEFT">
                     <VBox styleClass="card-icon-container">
                         <Label text="🛒" style="-fx-text-fill: -primary; -fx-font-size: 20px;" />
                     </VBox>
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 20px;" text="Commandes" />
                 </HBox>
                 <Label style="-fx-text-fill: -muted; -fx-font-size: 12px; -fx-wrap-text: true;" text="Surveillez l'état des demandes de sang et gérez les validations en temps réel." />
                 <Region VBox.vgrow="ALWAYS" minHeight="20.0" />
                 <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="card-btn-outline" text="Voir commandes" />
             </VBox>
             
             <VBox prefWidth="320.0" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                 <HBox spacing="15.0" alignment="CENTER_LEFT">
                     <VBox styleClass="card-icon-container">
                         <Label text="📦" style="-fx-text-fill: -primary; -fx-font-size: 20px;" />
                     </VBox>
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 20px;" text="Stocks" />
                 </HBox>
                 <Label style="-fx-text-fill: -muted; -fx-font-size: 12px; -fx-wrap-text: true;" text="Vérifiez les niveaux de sang disponibles par type et par organisation." />
                 <Region VBox.vgrow="ALWAYS" minHeight="20.0" />
                 <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="card-btn-outline" text="Gérer les stocks" />
             </VBox>
         </HBox>
         
         <!-- Actions Rapides -->
         <VBox spacing="15.0">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label style="-fx-text-fill: -primary;" text="≡" />
                <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 14px;" text="ACTIONS RAPIDES" />
            </HBox>
            <HBox spacing="15.0">
                <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0">
                    <Label text="📅" style="-fx-text-fill: -primary; -fx-font-size: 24px;" />
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Rendez-vous" />
                </VBox>
                <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0">
                    <Label text="📝" style="-fx-text-fill: -primary; -fx-font-size: 24px;" />
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Questionnaires" />
                </VBox>
                <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0">
                    <Label text="🏥" style="-fx-text-fill: -primary; -fx-font-size: 24px;" />
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Banques" />
                </VBox>
                <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0">
                    <Label text="⚙️" style="-fx-text-fill: -primary; -fx-font-size: 24px;" />
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Paramètres" />
                </VBox>
            </HBox>
         </VBox>
      </VBox>
   </center>
</BorderPane>
