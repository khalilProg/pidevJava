<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@commande.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AgentBanqueViewDemandeController" spacing="25"
      styleClass="main-content" style="-fx-padding: 40 50;">

    <Button text="← Retour aux demandes" styleClass="retour-button" onAction="#goBack"/>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="BLOODLINK" styleClass="breadcrumb-label" />
            <Label fx:id="lblTitle" text="Demande #25" styleClass="admin-page-title" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="lblCreatedAt" text="Créée le 22 Apr 2026 à 18:44" styleClass="page-subtitle" />
            </HBox>
        </VBox>

        <Label fx:id="lblStatusTop" text="● En Attente de Validation" style="-fx-background-color: rgba(255, 193, 7, 0.1); -fx-text-fill: #ffc107; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 20;"/>
    </HBox>

    <VBox spacing="25" styleClass="form-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
            <VBox>
                <Label text="INFORMATIONS DÉTAILLÉES" styleClass="form-title" />
                <Label text="Récapitulatif des besoins en produits sanguins." styleClass="form-description" />
            </VBox>
        </HBox>

        <FlowPane hgap="20" vgap="20">
            <!-- Card 1 -->
            <VBox spacing="10" prefWidth="250" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="TYPE DE SANG" styleClass="field-label" />
                <Label fx:id="lblType" text="A+" style="-fx-text-fill: #e74c3c; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Card 2 -->
            <VBox spacing="10" prefWidth="250" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="QUANTITÉ" styleClass="field-label" />
                <HBox spacing="5" alignment="BASELINE_LEFT">
                    <Label fx:id="lblQuantite" text="10" styleClass="card-title" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="unités" styleClass="page-subtitle" />
                </HBox>
            </VBox>

            <!-- Card 3 -->
            <VBox spacing="10" prefWidth="250" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="URGENCE" styleClass="field-label" />
                <Label fx:id="lblUrgence" text="Normale" styleClass="card-subtitle" style="-fx-padding: 4 12; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Card 4 -->
            <VBox spacing="10" prefWidth="300" styleClass="glass-card" style="-fx-padding: 20;">
                <Label text="BANQUE CIBLE" styleClass="field-label" />
                <Label fx:id="lblBanque" text="Mahmoud El Matri Hospital" styleClass="card-title" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>
        </FlowPane>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 30 0 0 0;">
            <Button text="Modifier" styleClass="cancel-button" onAction="#handleEdit"/>
            <Button text="Supprimer" styleClass="action-btn-delete" style="-fx-padding: 10 25; -fx-background-radius: 20; -fx-border-radius: 20;" onAction="#handleDelete"/>
        </HBox>
    </VBox>
</VBox>
