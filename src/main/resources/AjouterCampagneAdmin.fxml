<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AjouterCampagneAdmin">
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="260.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="🩸" style="-fx-text-fill: #e63939; -fx-font-size: 20px;" />
            <Label styleClass="logo-text" style="-fx-font-size: 18px;" text="BLOODLINK" />
            <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 2 6; -fx-background-radius: 10px; -fx-font-weight: bold;" text="ADMIN" />
         </HBox>
         
         <Region prefHeight="30.0" />
         <Label styleClass="sidebar-category" text="GESTION" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDashboard" styleClass="sidebar-item" text="    Dashboard" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateUsers" styleClass="sidebar-item" text="👥  Utilisateurs" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🛒  Commandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📦  Stocks" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateDemandes" styleClass="sidebar-item" text="📄  Demandes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateTransferts" styleClass="sidebar-item" text="🚚  Transferts" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateQuestionnaires" styleClass="sidebar-item" text="📝  Questionnaires" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateRendezVous" styleClass="sidebar-item" text="📅  Rendez-vous" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCampagnes" styleClass="sidebar-item, sidebar-item-active" text="📢  Campagnes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateCollectes" styleClass="sidebar-item" text="🏥  Collectes" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="🩸  Dons" />
         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-item" text="📁  Dossiers" />
         
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-background-color: -primary; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 8px; -fx-background-radius: 20px;" text="👤" />
                <VBox>
                    <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Admin Utilisateur" />
                    <Label style="-fx-text-fill: -muted; -fx-font-size: 10px;" text="Administrateur" />
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-border-color: -primary; -fx-border-radius: 20px; -fx-text-fill: -primary; -fx-cursor: hand; -fx-padding: 8;" text="⏻ Déconnexion" />
         </VBox>
      </VBox>
   </left>

   <center>
      <VBox styleClass="main-content" spacing="35.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="80.0" right="80.0" top="40.0" />
         </padding>

         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="Nouvelle Campagne" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Interface d'administration" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="← Retour à la liste" onAction="#handleRetour" style="-fx-background-color: transparent; -fx-text-fill: -muted; -fx-font-weight: bold; -fx-cursor: hand;" />
         </HBox>

         <VBox styleClass="glass-card" spacing="25.0" VBox.vgrow="ALWAYS">
            
            <VBox spacing="5.0">
               <Label text="Titre de la campagne" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <TextField fx:id="titreInput" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;" />
               <Label fx:id="titreError" text="Donnez un titre accrocheur à votre campagne." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <VBox spacing="5.0">
               <Label text="Description" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <TextArea fx:id="descInput" prefRowCount="3" style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-color: transparent;" />
               <Label fx:id="descError" text="Décrivez les objectifs et les détails de la campagne." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <HBox spacing="20.0">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Date de début" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <DatePicker fx:id="dateDebutInput" promptText="mm / dd / yyyy" style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;" maxWidth="1.7976931348623157E308"/>
                    <Label fx:id="dateDebutError" text="Quand commence la campagne ?" style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Date de fin" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <DatePicker fx:id="dateFinInput" promptText="mm / dd / yyyy" style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;" maxWidth="1.7976931348623157E308"/>
                    <Label fx:id="dateFinError" text="Quand se termine la campagne ?" style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
                </VBox>
            </HBox>

            <VBox spacing="5.0">
               <Label text="Type(s) de sang" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <FlowPane hgap="10" vgap="10" style="-fx-padding: 15px; -fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;">
                    <ToggleButton fx:id="tglAplus" text="A+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglAminus" text="A-" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglBplus" text="B+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglBminus" text="B-" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglABplus" text="AB+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglABminus" text="AB-" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglOplus" text="O+" styleClass="toggle-blood-type" />
                    <ToggleButton fx:id="tglOminus" text="O-" styleClass="toggle-blood-type" />
               </FlowPane>
               <Label fx:id="typesError" text="Sélectionnez les groupes sanguins ciblés." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <VBox spacing="5.0">
               <Label text="Lieu(x) de Collecte Associé(s)" style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <FlowPane fx:id="entitesFlowPane" hgap="10" vgap="10" style="-fx-padding: 15px; -fx-background-color: #1a1a1a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8;">
                    <!-- Dynamically populated from Java Controller -->
               </FlowPane>
               <Label fx:id="entitesError" text="Sélectionnez une ou plusieurs entités pour la campagne." style="-fx-text-fill: -muted; -fx-font-size: 11px;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button mnemonicParsing="false" text="Créer la campagne" onAction="#handleCreer" styleClass="button-primary" style="-fx-font-size: 16px; -fx-padding: 15px; -fx-background-radius: 8px;" maxWidth="1.7976931348623157E308"/>
            
         </VBox>
      </VBox>
   </center>
</BorderPane>
