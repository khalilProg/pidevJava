<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.EditDemandeController"
            prefHeight="350" prefWidth="450"
            stylesheets="@style.css">

    <children>

        <VBox spacing="12" layoutX="30" layoutY="30" prefWidth="390">

            <!-- TITLE -->
            <Label text="Modifier Demande"
                   styleClass="form-title"/>

            <!-- TYPE -->
            <TextField fx:id="txtType"
                       promptText="Type de sang"/>

            <!-- QUANTITE -->
            <TextField fx:id="txtQuantite"
                       promptText="Quantité"/>

            <!-- STATUS -->
            <ComboBox fx:id="comboStatus"
                      promptText="Status"/>

            <!-- BUTTONS -->
            <HBox spacing="10">

                <Button text="Save"
                        onAction="#updateDemande"
                        styleClass="btn-primary"/>

                <Button text="Retour"
                        onAction="#retour"
                        styleClass="btn-secondary"/>

            </HBox>

        </VBox>

    </children>
</AnchorPane>
