<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.addDemandeController">
   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <!-- HEADER -->
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="NOUVELLE DEMANDE" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Créer une nouvelle demande de transfert sanguin." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="← RETOUR" onAction="#goBack" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
         </HBox>

         <!-- FORM CARD -->
         <VBox styleClass="glass-card" spacing="25.0" maxWidth="600">
             
            <!-- BANQUE -->
            <VBox spacing="8.0">
                <Label styleClass="form-label" text="IDENTIFIANT BANQUE" />
                <TextField fx:id="txtBanque" promptText="ID Banque" styleClass="text-field-custom" />
            </VBox>

            <!-- TYPE DE SANG -->
            <VBox spacing="8.0">
                <Label styleClass="form-label" text="TYPE DE SANG" />
                <ComboBox fx:id="comboType" promptText="Type de sang" styleClass="text-field-custom" prefWidth="600">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="A+" />
                            <String fx:value="A-" />
                            <String fx:value="B+" />
                            <String fx:value="B-" />
                            <String fx:value="O+" />
                            <String fx:value="O-" />
                            <String fx:value="AB+" />
                            <String fx:value="AB-" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <!-- QUANTITE -->
            <VBox spacing="8.0">
                <Label styleClass="form-label" text="QUANTITÉ" />
                <TextField fx:id="txtQuantite" promptText="Quantité" styleClass="text-field-custom" />
            </VBox>

            <!-- URGENCE -->
            <VBox spacing="8.0">
                <Label styleClass="form-label" text="NIVEAU D'URGENCE" />
                <ComboBox fx:id="comboUrgence" promptText="Urgence" styleClass="text-field-custom" prefWidth="600">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="FAIBLE" />
                            <String fx:value="MOYENNE" />
                            <String fx:value="ELEVEE" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <Region prefHeight="10" />

            <Button mnemonicParsing="false" onAction="#ajouterDemande" styleClass="button-primary" text="ENREGISTRER LA DEMANDE" prefWidth="600" />
            
         </VBox>

      </VBox>
   </center>
</BorderPane>
