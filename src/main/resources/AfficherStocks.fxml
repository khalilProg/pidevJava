<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-container" stylesheets="@commande.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AfficherStocksController">
    <!-- TOP NAV BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label styleClass="brand-icon" text="🩸" />
                <Label styleClass="brand-label" text="BLOODLINK" />
            </HBox>
            
            <HBox alignment="CENTER" spacing="20" HBox.hgrow="ALWAYS">
                <Button onAction="#goToCommandes" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: hand; -fx-font-weight: bold;" text="📦 Commandes" />
                <Button onAction="#goToStocks" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="🏢 Stocks" />
            </HBox>
            
            <Button styleClass="user-badge" text="👤  Admin UI" />
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #121212;">
            <padding>
                <Insets bottom="32" left="32" right="32" top="28" />
            </padding>

            <!-- Page Header -->
            <VBox spacing="0">
                <Label styleClass="breadcrumb-label" text="BLOODLINK" />
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size: 24px;" text="📦" />
                    <Label styleClass="page-title" text="Inventaire des" />
                    <Label styleClass="page-title-highlight" text="Stocks" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnNouvelleStock" styleClass="submit-button" text="＋ Nouveau stock" />
                </HBox>
                <Label styleClass="page-subtitle" text="Gérez et consultez l'inventaire des poches de sang." />
            </VBox>

            <!-- Table Card -->
            <VBox spacing="10" styleClass="form-card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-text-fill: #777777; -fx-font-size: 11px; -fx-font-weight: bold;" text="HISTORIQUE DES STOCKS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotalCount" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="0 stock(s)" />
                </HBox>
                
                <TableView fx:id="tableStocks" styleClass="dark-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTypeOrg" prefWidth="180" text="TYPE ORGANISATION" />
                        <TableColumn fx:id="colOrganisation" prefWidth="250" text="NOM ORGANISATION" />
                        <TableColumn fx:id="colTypeSang" prefWidth="120" text="TYPE SANG" />
                        <TableColumn fx:id="colQuantite" prefWidth="120" text="QUANTITÉ" />
                        <TableColumn fx:id="colDate" prefWidth="180" text="MODIFIÉ LE" />
                        <TableColumn fx:id="colActions" prefWidth="150" text="ACTIONS" style="-fx-alignment: center-right;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
