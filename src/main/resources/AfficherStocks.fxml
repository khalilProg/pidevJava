<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@commande.css" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AfficherStocksController">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <left><fx:include fx:id="sidebar" source="admin_sidebar.fxml" /></left>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <VBox spacing="20" styleClass="content-area">
            <padding>
                <Insets bottom="32" left="32" right="32" top="28"/>
            </padding>

            <!-- Page Header -->
            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="page-title" text="STOCKS DE SANG"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnNouvelleStock" styleClass="nouveau-btn" text="＋ NOUVEAU STOCK"/>
                </HBox>
                <Label styleClass="page-subtitle" text="Surveillez et ajustez les niveaux de stock disponibles par organisation."/>
            </VBox>

            <!-- Search + Filters Bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="tfSearch" prefWidth="300" promptText="🔍  Rechercher par type, organisation..." styleClass="dark-field"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Toutes organisations" styleClass="filter-btn"/>
                <Button text="Tous les types" styleClass="filter-btn"/>
            </HBox>

            <!-- Table -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="lblTotalCount" text="0 stock(s)"/>
                </HBox>

                <TableView fx:id="tableStocks" styleClass="dark-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80" text="ID"/>
                        <TableColumn fx:id="colTypeSang" prefWidth="120" text="TYPE SANG"/>
                        <TableColumn fx:id="colQuantite" prefWidth="120" text="QUANTITÉ"/>
                        <TableColumn fx:id="colOrganisation" prefWidth="160" text="ORGANISATION"/>
                        <TableColumn fx:id="colDate" prefWidth="180" text="DATE DE CRÉATION"/>
                        <TableColumn fx:id="colActions" prefWidth="200" text="ACTIONS" style="-fx-alignment: center-right;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
