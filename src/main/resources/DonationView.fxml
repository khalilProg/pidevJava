<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="750.0" prefWidth="1250.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DonationListController">
    <stylesheets><URL value="@style.css" /></stylesheets>

    <HBox spacing="0">
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar-glass">
            <padding><Insets bottom="30.0" left="25.0" right="25.0" top="40.0" /></padding>
            <children>
                <VBox spacing="5.0">
                    <Label styleClass="logo-text" text="BLOODLINK" />
                    <Label styleClass="logo-subtext" text="INTELLIGENT SYSTEMS" />
                </VBox>
                <Region prefHeight="60.0" />
                <VBox spacing="10.0">
                    <Button styleClass="nav-btn" text="📊 Dashboard" />
                    <Button onAction="#goToMedicalFolders" styleClass="nav-btn" text="🩺 Medical Folders" />
                    <Button styleClass="nav-btn-active" text="🩸 Donation Logs" />
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <VBox styleClass="ai-mini-card" spacing="10">
                    <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                    <Label styleClass="ai-label" text="INVENTORY AI" />
                    <Label styleClass="ai-status" text="Optimal Levels" />
                </VBox>
            </children>
        </VBox>

        <VBox styleClass="main-content" HBox.hgrow="ALWAYS" spacing="25.0">
            <padding><Insets bottom="30.0" left="35.0" right="35.0" top="35.0" /></padding>
            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label styleClass="hero-title" text="Inventory Intelligence" />
                    <Label styleClass="hero-subtitle" text="Tracking donation flow and supply chain stability." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="searchField" prefWidth="300" promptText="Search donation ID or type..." styleClass="search-glass" />
            </HBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <TableView fx:id="donationTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                            <TableColumn fx:id="colClientId" prefWidth="100" text="Client ID" />
                            <TableColumn fx:id="colEntityId" prefWidth="100" text="Entity" />
                            <TableColumn fx:id="colType" prefWidth="150" text="Type" />
                            <TableColumn fx:id="colQte" prefWidth="100" text="Volume" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox prefWidth="380.0" minWidth="380.0" styleClass="glass-card" spacing="20.0">
                    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                    <Label styleClass="form-title" text="Donation Entry" />
                    <VBox spacing="5"><Label styleClass="field-label" text="Client ID" /><TextField fx:id="clientIdField" styleClass="input-glass" /></VBox>
                    <VBox spacing="5"><Label styleClass="field-label" text="Entity ID" /><TextField fx:id="entityIdField" styleClass="input-glass" /></VBox>
                    <VBox spacing="5"><Label styleClass="field-label" text="Type" /><TextField fx:id="typeField" styleClass="input-glass" /></VBox>
                    <VBox spacing="5"><Label styleClass="field-label" text="Volume (ml)" /><TextField fx:id="qteField" styleClass="input-glass" /></VBox>
                    <Region VBox.vgrow="ALWAYS" />
                    <VBox spacing="10">
                        <Button onAction="#handleAddDonation" maxWidth="Infinity" styleClass="btn-primary-glow" text="Log New Donation" />
                        <HBox spacing="10">
                            <Button onAction="#handleUpdateDonation" maxWidth="Infinity" styleClass="btn-secondary" text="Edit" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleDeleteDonation" maxWidth="Infinity" styleClass="btn-danger-outline" text="Delete" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</StackPane>