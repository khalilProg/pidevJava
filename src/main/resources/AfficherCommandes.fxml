<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@commande.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AfficherCommandesController">
    <children>
<BorderPane styleClass="main-container">
    <!-- TOP NAV BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label styleClass="brand-label" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnThemeToggle" text="☀  Light" styleClass="theme-toggle-btn" onAction="#handleThemeToggle"/>
            <Region prefWidth="12"/>
            <Button styleClass="user-badge" text="👤  chaffai yassine" />
            <Region prefWidth="12"/>
            <Button fx:id="menuToggleBtn" mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="menu-toggle" text="MENU" />
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" styleClass="content-area">
            <padding>
                <Insets bottom="32" left="32" right="32" top="28" />
            </padding>

            <!-- Page Header -->
            <VBox spacing="0">
                <Label styleClass="breadcrumb-label" text="BLOODLINK" />
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size: 24px;" text="📦" />
                    <Label styleClass="page-title" text="Mes Commandes" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleNouvelleCommande" styleClass="submit-button" text="＋ Nouvelle commande" />
                </HBox>
                <Label styleClass="page-subtitle" text="Consultez et suivez l'état de vos commandes de produits sanguins." />
            </VBox>

            <!-- Filters Bar -->
            <HBox spacing="16">
                <TextField fx:id="tfSearch" prefWidth="350" promptText="🔍  Référence, groupe sanguin..." styleClass="dark-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbStatutFiltre" prefWidth="250" promptText="Statuts" styleClass="dark-combo" />
                <ComboBox fx:id="cbPrioriteFiltre" prefWidth="250" promptText="Priorités" styleClass="dark-combo" />
            </HBox>

            <!-- Table Card -->
            <VBox spacing="10" styleClass="form-card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="field-label" text="HISTORIQUE DES COMMANDES" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblCount" text="0 commande(s)" />
                </HBox>
                
                <TableView fx:id="tableCommandes" styleClass="dark-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colReference" prefWidth="120" text="RÉFÉRENCE" />
                        <TableColumn fx:id="colTypeSang" prefWidth="150" text="TYPE SANG" />
                        <TableColumn fx:id="colQuantite" prefWidth="120" text="QUANTITÉ" />
                        <TableColumn fx:id="colPriorite" prefWidth="150" text="PRIORITÉ" />
                        <TableColumn fx:id="colStatut" prefWidth="150" text="STATUT" />
                        <TableColumn fx:id="colActions" prefWidth="180" text="ACTIONS" style="-fx-alignment: center;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
        </BorderPane>

        <VBox alignment="BOTTOM_RIGHT" pickOnBounds="false" spacing="14.0" StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets bottom="30.0" right="30.0" />
            </StackPane.margin>
            <children>
                <VBox fx:id="chatbotWindow" managed="false" maxHeight="550.0" maxWidth="380.0" prefHeight="550.0" prefWidth="380.0" spacing="0.0" styleClass="chatbot-window" visible="false">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="chatbot-header">
                            <children>
                                <Label styleClass="chatbot-header-avatar" text="AI" />
                                <VBox spacing="1.0">
                                    <children>
                                        <Label styleClass="chatbot-title" text="BloodLink Assistant" />
                                        <Label styleClass="chatbot-status" text="Online" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleChatbotClose" styleClass="chatbot-close" text="X" />
                            </children>
                        </HBox>
                        <ScrollPane fx:id="chatbotScroll" fitToWidth="true" hbarPolicy="NEVER" styleClass="chatbot-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="chatbotMessages" spacing="12.0" styleClass="chatbot-messages" />
                            </content>
                        </ScrollPane>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="chatbot-input-bar">
                            <children>
                                <TextField fx:id="chatbotInput" onAction="#handleChatbotSubmit" promptText="Ask me a question..." styleClass="chatbot-input" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleChatbotSubmit" styleClass="chatbot-send" text="&gt;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <Button fx:id="chatbotToggleBtn" mnemonicParsing="false" onAction="#handleChatbotToggle" styleClass="chatbot-toggle" text="MSG" />
            </children>
        </VBox>

        <HBox fx:id="menuOverlay" alignment="CENTER_RIGHT" managed="false" visible="false">
            <children>
                <Region onMouseClicked="#handleMenuClose" styleClass="menu-backdrop" HBox.hgrow="ALWAYS" />
                <VBox fx:id="menuPanel" alignment="TOP_LEFT" prefWidth="380.0" spacing="15.0" styleClass="menu-panel">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleMenuToggle" styleClass="submit-button" text="FERMER" />
                            </children>
                        </HBox>
                        <Region prefHeight="20.0" />
                        <Button mnemonicParsing="false" onAction="#goToAccueil" styleClass="menu-link" text="ACCUEIL" />
                        <Button mnemonicParsing="false" onAction="#goToCampagnes" styleClass="menu-link" text="CAMPAGNES" />
                        <Button mnemonicParsing="false" onAction="#goToHistorique" styleClass="menu-link" text="HISTORIQUE" />
                        <Button mnemonicParsing="false" onAction="#goToCommandes" styleClass="menu-link, menu-link-active" text="COMMANDES" />
                        <Button mnemonicParsing="false" styleClass="menu-link" text="DOSSIER MEDICAL" />
                        <Button mnemonicParsing="false" onAction="#goToProfile" styleClass="menu-link" text="MON PROFIL" />
                        <Region VBox.vgrow="ALWAYS" />
                        <VBox spacing="15.0">
                            <children>
                                <Label fx:id="sessionEmailLabel" styleClass="menu-session" text="Session: utilisateur@email.com" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="submit-button" text="DECONNEXION" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
