<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AfficherCommandesController">
    <!-- TOP NAV BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Region styleClass="logo-icon" />
                <Label styleClass="brand-label" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnThemeToggle" text="☀  Light" styleClass="theme-toggle-btn" onAction="#handleThemeToggle"/>
            <Region prefWidth="12"/>
            <Button styleClass="user-badge" text="👤  chaffai yassine" />
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" styleClass="content-area">
            <padding>
                <Insets bottom="32" left="32" right="32" top="28" />
            </padding>

            <!-- Page Header -->
            <VBox spacing="0">
                <Label styleClass="breadcrumb-label" text="BLOODLINK" />
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size: 24px;" text="📦" />
                    <Label styleClass="page-title" text="Mes Commandes" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleNouvelleCommande" styleClass="submit-button" text="＋ Nouvelle commande" />
                </HBox>
                <Label styleClass="page-subtitle" text="Consultez et suivez l'état de vos commandes de produits sanguins." />
            </VBox>

            <!-- Filters Bar -->
            <HBox spacing="16">
                <TextField fx:id="tfSearch" prefWidth="350" promptText="🔍  Référence, groupe sanguin..." styleClass="dark-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbStatutFiltre" prefWidth="250" promptText="Statuts" styleClass="dark-combo" />
                <ComboBox fx:id="cbPrioriteFiltre" prefWidth="250" promptText="Priorités" styleClass="dark-combo" />
            </HBox>

            <!-- Table Card -->
            <VBox spacing="10" styleClass="form-card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="field-label" text="HISTORIQUE DES COMMANDES" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblCount" text="0 commande(s)" />
                </HBox>
                
                <TableView fx:id="tableCommandes" styleClass="dark-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colReference" prefWidth="120" text="RÉFÉRENCE" />
                        <TableColumn fx:id="colTypeSang" prefWidth="150" text="TYPE SANG" />
                        <TableColumn fx:id="colQuantite" prefWidth="120" text="QUANTITÉ" />
                        <TableColumn fx:id="colPriorite" prefWidth="150" text="PRIORITÉ" />
                        <TableColumn fx:id="colStatut" prefWidth="150" text="STATUT" />
                        <TableColumn fx:id="colActions" prefWidth="180" text="ACTIONS" style="-fx-alignment: center;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
