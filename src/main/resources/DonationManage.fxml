<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DonationManageController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <StackPane styleClass="main-container" />
    <Circle radius="400.0" fill="#e63939" opacity="0.06" StackPane.alignment="CENTER" />

    <VBox spacing="0">
        <HBox alignment="CENTER" minHeight="90.0" styleClass="nav-bar">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Circle fill="#e63939" radius="8.0" />
                <Label styleClass="brand-label" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="20">
                <Label styleClass="sidebar-nav-item-active" text="Surcharge de Protocole" />
                <Button onAction="#closeWindow" styleClass="sidebar-nav-item" text="Retour à l'Inventaire" />
            </HBox>
            <padding><Insets left="50.0" right="50.0" /></padding>
        </HBox>

        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="40" top="20"/></padding>

            <VBox maxWidth="550" spacing="30" styleClass="form-card" style="-fx-border-color: rgba(230, 57, 57, 0.3);">
                <padding><Insets bottom="50" left="50" right="50" top="50" /></padding>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox alignment="CENTER" prefHeight="50" prefWidth="50" style="-fx-background-color: rgba(230, 57, 57, 0.15); -fx-background-radius: 12;">
                        <Label style="-fx-text-fill: #e63939; -fx-font-size: 24; -fx-font-weight: 900;" text="!" />
                    </VBox>
                    <VBox spacing="5">
                        <Label styleClass="breadcrumb-label" text="ADMIN / SÉCURITÉ / SURCHARGE" />
                        <Label styleClass="page-title" text="Modifier le Protocole" />
                        <Label fx:id="donHeaderIdInfo" styleClass="page-subtitle" text="Numéro de Suivi #----" />
                    </VBox>
                </HBox>

                <Separator opacity="0.1" />

                <VBox spacing="25">
                    <HBox spacing="20">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="VOLUME MODIFIÉ (ML)" />
                            <TextField fx:id="qteField" styleClass="dark-field" promptText="Saisir le volume corrigé" />
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="CATÉGORIE CORRIGÉE" />
                            <TextField fx:id="typeField" styleClass="dark-field" promptText="Plasma / Complet / etc." />
                        </VBox>
                    </HBox>

                    <VBox spacing="10" style="-fx-background-color: rgba(230, 57, 57, 0.05); -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: rgba(230, 57, 57, 0.2); -fx-border-width: 1;">
                        <Label styleClass="field-error" text="AVERTISSEMENT CRITIQUE SUR L'INTÉGRITÉ DES DONNÉES" />
                        <Label styleClass="admin-card-copy" text="La modification du volume médical altère le suivi historique global. Assurez-vous d'une vérification clinique avant l'exécution." wrapText="true" />
                    </VBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" minHeight="20" />

                <VBox spacing="15">
                    <Button maxWidth="Infinity" onAction="#handleUpdateDonation" styleClass="submit-button" text="Appliquer les Modifications" />

                    <HBox alignment="CENTER" spacing="10">
                        <Separator HBox.hgrow="ALWAYS" opacity="0.1" />
                        <Label styleClass="field-label" text="OU" />
                        <Separator HBox.hgrow="ALWAYS" opacity="0.1" />
                    </HBox>

                    <Button maxWidth="Infinity" onAction="#handleDeleteDonation" styleClass="action-btn-delete" text="Purger l'Enregistrement" prefHeight="42" />
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</StackPane>