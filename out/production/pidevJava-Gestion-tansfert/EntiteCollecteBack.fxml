<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="800.0" stylesheets="@commande.css" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.EntiteCollecteBackController">
   <children>
      <Label layoutX="32.0" layoutY="28.0" text="Entités de Collecte (Back-Office)" styleClass="hero-title-main">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <TextField fx:id="txtRecherche" layoutX="32.0" layoutY="100.0" prefHeight="35.0" prefWidth="256.0" promptText="Recherche..." styleClass="text-field" />
      <Button fx:id="btnTrier" layoutX="300.0" layoutY="100.0" mnemonicParsing="false" onAction="#handleTrier" text="⬇ Trier de A - Z" styleClass="btn-outline" />

      <TableView fx:id="tableEntite" layoutX="32.0" layoutY="155.0" prefHeight="400.0" prefWidth="736.0" styleClass="table-view">
        <columns>
          <TableColumn prefWidth="75.0" text="ID" />
          <TableColumn prefWidth="150.0" text="Nom" />
            <TableColumn prefWidth="120.0" text="Téléphone" />
            <TableColumn prefWidth="150.0" text="Type" />
            <TableColumn prefWidth="200.0" text="Adresse" />
        </columns>
      </TableView>
      <Button fx:id="btnAjouter" layoutX="32.0" layoutY="580.0" mnemonicParsing="false" onAction="#handleAjouter" text="+ Ajouter" styleClass="btn-primary-modern" />
      <Button fx:id="btnModifier" layoutX="140.0" layoutY="580.0" mnemonicParsing="false" onAction="#handleModifier" text="✏ Modifier" styleClass="btn-outline" />
      <Button fx:id="btnSupprimer" layoutX="265.0" layoutY="580.0" mnemonicParsing="false" onAction="#handleSupprimer" text="🗑 Supprimer" styleClass="btn-outline" />
   </children>
</AnchorPane>
