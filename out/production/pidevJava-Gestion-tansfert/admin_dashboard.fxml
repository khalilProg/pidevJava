<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@commande.css" styleClass="main-container" prefHeight="900.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin_dashboard">

   <!-- Sidebar -->
   <left><fx:include fx:id="sidebar" source="admin_sidebar.fxml" /></left>

   <!-- Main Content -->
   <center>
      <ScrollPane fitToWidth="true" styleClass="edge-to-edge-scroll">
         <VBox styleClass="main-content" spacing="30.0">
            <padding>
               <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <!-- Header Board -->
            <VBox styleClass="dashboard-header-bg" spacing="10.0">
                <Label style="-fx-text-fill: #e74c3c; -fx-font-weight: 800; -fx-font-size: 12px;" text="BLOODLINK ADMINISTRATION" />
                <Label style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: 900;" text="Bienvenue, Administrateur 👋" />
                <Label style="-fx-text-fill: #888888; -fx-font-size: 14px;" text="Vous êtes sur le centre de contrôle de BloodLink. Gérez les stocks, suivez les&#10;commandes et supervisez la communauté des donneurs en toute simplicité." />
                <Region prefHeight="10.0" />
                <Button mnemonicParsing="false" styleClass="button-primary" text="👤 + NOUVEL UTILISATEUR" onAction="#handleNavigateUsers" />
            </VBox>

            <!-- 3 KPI Cards -->
            <HBox spacing="20.0">
                <VBox prefWidth="320.0" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <VBox styleClass="card-icon-container">
                            <Label text="👥" style="-fx-font-size: 20px;" />
                        </VBox>
                        <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 20px;" text="Utilisateurs" />
                    </HBox>
                    <Label fx:id="totalUsersLabel" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="0" />
                    <Label style="-fx-text-fill: #888888; -fx-font-size: 12px; -fx-wrap-text: true;" text="Gérez les comptes, les rôles et accédez aux profils détaillés des donneurs et banques." />
                    <Region VBox.vgrow="ALWAYS" minHeight="20.0" />
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="card-btn-outline" text="Ouvrir la liste" onAction="#handleNavigateUsers" />
                </VBox>

                <VBox prefWidth="320.0" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <VBox styleClass="card-icon-container">
                            <Label text="📦" style="-fx-font-size: 20px;" />
                        </VBox>
                        <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 20px;" text="Commandes" />
                    </HBox>
                    <Label fx:id="totalDemandesLabel" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="0" />
                    <Label style="-fx-text-fill: #888888; -fx-font-size: 12px; -fx-wrap-text: true;" text="Surveillez l'état des demandes de sang et gérez les validations en temps réel." />
                    <Region VBox.vgrow="ALWAYS" minHeight="20.0" />
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="card-btn-outline" text="Voir commandes" onAction="#handleNavigateCommandes" />
                </VBox>

                <VBox prefWidth="320.0" styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="15.0">
                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <VBox styleClass="card-icon-container">
                            <Label text="🏢" style="-fx-font-size: 20px;" />
                        </VBox>
                        <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 20px;" text="Stocks" />
                    </HBox>
                    <Label fx:id="totalStockLabel" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="0 L" />
                    <Label style="-fx-text-fill: #888888; -fx-font-size: 12px; -fx-wrap-text: true;" text="Vérifiez les niveaux de sang disponibles par type et par organisation." />
                    <Region VBox.vgrow="ALWAYS" minHeight="20.0" />
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="card-btn-outline" text="Gérer les stocks" onAction="#handleNavigateStocks" />
                </VBox>
            </HBox>
             <!-- Actions Rapides -->
             <VBox spacing="15.0">
                 <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <Label style="-fx-text-fill: #e74c3c;" text="≡" />
                     <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 14px;" text="ACTIONS RAPIDES" />
                 </HBox>
                 <HBox spacing="15.0">
                     <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0" onMouseClicked="#handleNavigateRendezVousClick">
                         <Label text="📅" style="-fx-font-size: 24px;" />
                         <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Rendez-vous" />
                     </VBox>
                     <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0" onMouseClicked="#handleNavigateQuestionnairesClick">
                         <Label text="📝" style="-fx-font-size: 24px;" />
                         <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Questionnaires" />
                     </VBox>
                     <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0" onMouseClicked="#handleNavigateCollectesClick">
                         <Label text="🏥" style="-fx-font-size: 24px;" />
                         <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Collectes" />
                     </VBox>
                     <VBox alignment="CENTER" prefWidth="250.0" styleClass="glass-card" style="-fx-padding: 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" spacing="10.0" onMouseClicked="#handleNavigateCampagnesClick">
                         <Label text="📢" style="-fx-font-size: 24px;" />
                         <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Campagnes" />
                     </VBox>
                 </HBox>
             </VBox>
            <!-- Dashboard Charts -->
            <HBox prefHeight="420.0" spacing="20.0">
               <VBox prefWidth="600.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 18px;" text="Distribution du Stock" />
                  <PieChart fx:id="stockPieChart" animated="false" />
               </VBox>

               <VBox prefWidth="480.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 18px;" text="Etat des Demandes" />
                  <BarChart fx:id="demandeBarChart" legendVisible="false" animated="false">
                     <xAxis>
                        <CategoryAxis side="BOTTOM" tickLabelFill="WHITE" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis side="LEFT" tickLabelFill="WHITE" />
                     </yAxis>
                  </BarChart>
               </VBox>
            </HBox>

            <HBox prefHeight="420.0" spacing="20.0">
               <VBox prefWidth="600.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 18px;" text="Campagnes par Mois" />
                  <BarChart fx:id="campagneBarChart" legendVisible="false" animated="false">
                     <xAxis>
                        <CategoryAxis side="BOTTOM" tickLabelFill="WHITE" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis side="LEFT" tickLabelFill="WHITE" />
                     </yAxis>
                  </BarChart>
               </VBox>

               <VBox prefWidth="480.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 18px;" text="Rendez-vous par Statut" />
                  <PieChart fx:id="rdvPieChart" animated="false" />
               </VBox>
            </HBox>
         </VBox>
      </ScrollPane>
   </center>
</BorderPane>
