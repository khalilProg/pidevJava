<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@commande.css" prefHeight="900.0" prefWidth="1400.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.backDemandeController">
   
   <left><fx:include source="admin_sidebar.fxml" /></left>

   <center>
      <VBox styleClass="main-content" spacing="40.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
         
         <HBox alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="DEMANDES DE SANG" />
                <Label style="-fx-text-fill: -muted; -fx-font-size: 14px;" text="Gérez les demandes de sang et validez ou refusez les requêtes." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="+ NOUVELLE DEMANDE" onAction="#goToAddDemande" styleClass="button-primary" />
         </HBox>

         <VBox styleClass="glass-card" spacing="20.0" VBox.vgrow="ALWAYS">
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="text-field-custom" prefWidth="400.0">
                    <Label text="🔍" style="-fx-text-fill: -muted;" />
                    <TextField promptText="Rechercher par type, statut, banque..." styleClass="transparent-input" HBox.hgrow="ALWAYS" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button styleClass="submit-button" mnemonicParsing="false" text="Toutes urgenc" />
                <Button styleClass="filter-btn" mnemonicParsing="false" text="Tous statuts" />
            </HBox>

            <TableView fx:id="tableDemande" VBox.vgrow="ALWAYS" >
               <columns>
                  <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                  <TableColumn fx:id="colBanque" text="BANQUE" prefWidth="250"/>
                  <TableColumn fx:id="colType" text="TYPE SANG" prefWidth="100"/>
                  <TableColumn fx:id="colQuantite" text="QUANTITÉ" prefWidth="100"/>
                  <TableColumn fx:id="colUrgence" text="URGENCE" prefWidth="120"/>
                  <TableColumn fx:id="colStatus" text="STATUT" prefWidth="120"/>
                  <TableColumn fx:id="colDate" text="DATE" prefWidth="120"/>
                  <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="150"/>
               </columns>
            </TableView>
         </VBox>

      </VBox>
   </center>
</BorderPane>
