<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="750.0" prefWidth="1250.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DossierMedController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <Circle radius="300.0" fill="#e63939" opacity="0.04" StackPane.alignment="TOP_RIGHT" />
    <Circle radius="250.0" fill="#4a90e2" opacity="0.04" StackPane.alignment="BOTTOM_LEFT" />

    <HBox spacing="0">
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar-glass">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0" />
            </padding>
            <children>
                <VBox spacing="5.0">
                    <Label styleClass="logo-text" text="BLOODLINK" />
                    <Label styleClass="logo-subtext" text="INTELLIGENT SYSTEMS" />
                </VBox>

                <Region prefHeight="60.0" />

                <VBox spacing="10.0">
                    <Button onAction="#handleRefresh" styleClass="nav-btn" text="📊 Dashboard" />
                    <Button styleClass="nav-btn-active" text="🩺 Medical Folders" />
                    <Button onAction="#goToDonations" styleClass="nav-btn" text="🩸 Donation Logs" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="10" styleClass="ai-mini-card">
                    <padding>
                        <Insets bottom="15" left="15" right="15" top="15" />
                    </padding>
                    <Label styleClass="ai-label" text="AI STATUS" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle fill="#00ff88" radius="4" />
                        <Label styleClass="ai-status" text="Neural Engine Online" />
                    </HBox>
                </VBox>
            </children>
        </VBox>

        <VBox spacing="25.0" styleClass="main-content" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label styleClass="hero-title" text="Medical Intelligence" />
                    <Label styleClass="hero-subtitle" text="Real-time clinical records and AI diagnostics." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <TextField fx:id="searchField" prefWidth="300" promptText="Search fingerprint or name..." styleClass="search-glass" />
                    <Button onAction="#handleRefresh" styleClass="btn-icon" text="🔄" />
                </HBox>
            </HBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                <VBox spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <TableView fx:id="mainTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                            <TableColumn fx:id="colPrenom" prefWidth="130" text="First Name" />
                            <TableColumn fx:id="colNom" prefWidth="130" text="Last Name" />
                            <TableColumn fx:id="colAge" prefWidth="70" text="Age" />
                            <TableColumn fx:id="colBlood" prefWidth="100" text="Type" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox minWidth="380.0" prefWidth="380.0" spacing="25.0">

                    <VBox spacing="15" styleClass="ai-predictor-card">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 18px;" text="✨" />
                            <Label styleClass="ai-title" text="Clinical AI Insight" />
                        </HBox>
                        <Label fx:id="aiResultLabel" styleClass="ai-text" text="Select a patient to analyze donor eligibility." wrapText="true" />
                        <Button maxWidth="Infinity" onAction="#runAIPrediction" styleClass="ai-btn" text="Run AI Analysis" />
                    </VBox>

                    <VBox spacing="15.0" styleClass="glass-card" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                        </padding>
                        <Label styleClass="form-title" text="Folder Management" />

                        <GridPane hgap="12" vgap="12">
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="field-label" text="First Name" />
                                <TextField fx:id="prenomField" styleClass="input-glass" />
                            </VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="field-label" text="Last Name" />
                                <TextField fx:id="nomField" styleClass="input-glass" />
                            </VBox>
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="field-label" text="Weight (kg)" />
                                <TextField fx:id="poidField" styleClass="input-glass" />
                            </VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="field-label" text="Height (cm)" />
                                <TextField fx:id="tailleField" styleClass="input-glass" />
                            </VBox>
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label styleClass="field-label" text="Age" />
                                <TextField fx:id="ageField" styleClass="input-glass" />
                            </VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <Label styleClass="field-label" text="Blood" />
                                <TextField fx:id="bloodTypeField" styleClass="input-glass" />
                            </VBox>
                            <columnConstraints>
                                <ColumnConstraints />
                                <ColumnConstraints />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                        </GridPane>

                        <Region VBox.vgrow="ALWAYS" />

                        <VBox spacing="10">
                            <Button maxWidth="Infinity" onAction="#handleAddFolder" styleClass="btn-primary-glow" text="Save New Record" />
                            <HBox spacing="10">
                                <Button maxWidth="Infinity" onAction="#handleUpdateFolder" styleClass="btn-secondary" text="Update" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#handleDeleteFolder" styleClass="btn-danger-outline" text="Delete" HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</StackPane>