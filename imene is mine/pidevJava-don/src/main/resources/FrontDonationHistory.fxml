<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.FrontDonationController">
    <stylesheets><URL value="@style.css" /></stylesheets>

    <style>
        .root { -primary-red: #e63939; }
    </style>

    <StackPane styleClass="hero-glow-2" />

    <VBox spacing="0">
        <HBox alignment="CENTER" minHeight="90.0" styleClass="navbar-top">
            <HBox spacing="12.0" styleClass="brand-section">
                <Circle fill="#e63939" radius="8.0" />
                <Label styleClass="brand-text" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="30.0">
                <Button onAction="#goToMyProfile" styleClass="nav-link" text="Health Passport" />
                <Label styleClass="nav-link-active" text="Donation Legacy" />
                <HBox alignment="CENTER" spacing="12.0" styleClass="user-pill">
                    <Circle fill="#e63939" radius="12.0" />
                    <Label styleClass="user-name-label" text="Verified Donor" />
                </HBox>
                <Button onAction="#toggleMenu" styleClass="menu-button" text="SYSTEM ☰" />
            </HBox>
            <padding><Insets left="50.0" right="50.0" /></padding>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <VBox spacing="35.0">
                <padding><Insets bottom="50.0" left="50.0" right="50.0" top="40.0" /></padding>

                <HBox alignment="BOTTOM_LEFT" spacing="20">
                    <VBox spacing="8.0">
                        <Label styleClass="hero-title-large" text="Contribution Legacy." />
                        <Label styleClass="hero-description-v2" text="Historical ledger of biological intake and quantified community impact." />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15;">
                        <padding><Insets left="20" right="20" top="10" bottom="10"/></padding>
                        <Label styleClass="form-label" text="DONOR STANDING" />
                        <Label fx:id="rankLabel" style="-fx-font-size: 18; -fx-font-weight: 900;" text="INITIALIZING..." />
                    </VBox>
                </HBox>

                <HBox spacing="35.0">
                    <VBox spacing="20.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="form-label" text="VERIFIED TRANSACTION LOGS" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" prefWidth="250" promptText="Filter by center or type..." styleClass="dark-input" />
                        </HBox>

                        <TableView fx:id="donationTable" prefHeight="450.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="80" text="CERT #" />
                                <TableColumn fx:id="colEntityId" prefWidth="150" text="FACILITY ID" />
                                <TableColumn fx:id="colType" prefWidth="150" text="INTAKE TYPE" />
                                <TableColumn fx:id="colQte" prefWidth="120" text="YIELD (ML)" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>

                    <VBox minWidth="450.0" prefWidth="450.0" spacing="30.0">
                        <VBox spacing="25.0" styleClass="ai-predictor-card">
                            <padding><Insets bottom="40.0" left="30.0" right="30.0" top="40.0" /></padding>
                            <Label styleClass="ai-title" text="VITASPHERE LEGACY SYNTHESIS" />
                            <Label fx:id="aiImpactLabel" styleClass="ai-text" prefHeight="120" text="Initializing neural sync..." wrapText="true" />
                            <Button maxWidth="Infinity" onAction="#runImpactAnalysis" styleClass="btn-prime-home" text="GENERATE IMPACT METRICS" />
                        </VBox>

                        <VBox alignment="CENTER" spacing="15.0" styleClass="glass-card">
                            <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>
                            <Label styleClass="form-label" text="VITA-PASSPORT AUTHENTICATOR" />
                            <StackPane style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">
                                <ImageView fx:id="qrCodeImage" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
                            </StackPane>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="10.0" styleClass="glass-card">
                            <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
                            <Label styleClass="form-label" text="TOTAL GLOBAL YIELD" />
                            <HBox alignment="BASELINE_LEFT" spacing="10.0">
                                <Label fx:id="totalVolumeLabel" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: 900;" text="0.0" />
                                <Label style="-fx-text-fill: #e63939; -fx-font-weight: bold;" text="mL" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <VBox spacing="20.0" styleClass="glass-card">
                    <padding><Insets bottom="40.0" left="30.0" right="30.0" top="30.0" /></padding>
                    <Label styleClass="form-label" text="YIELD VOLUMETRIC ANALYSIS (TREND)" />
                    <BarChart fx:id="yieldChart" horizontalGridLinesVisible="false" legendVisible="false" prefHeight="300.0" verticalGridLinesVisible="false">
                        <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="GRAY" fx:id="barXAxis" /></xAxis>
                        <yAxis><NumberAxis side="LEFT" tickLabelFill="GRAY" fx:id="barYAxis" /></yAxis>
                    </BarChart>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>

    <Region fx:id="navBackdrop" mouseTransparent="true" onMouseClicked="#toggleMenu" opacity="0.0" style="-fx-background-color: rgba(0,0,0,0.85);" />

    <VBox fx:id="navMenuPanel" maxWidth="450.0" prefWidth="450.0" spacing="40.0" styleClass="menu-panel" translateX="450.0" StackPane.alignment="CENTER_RIGHT">
        <padding><Insets left="60.0" top="120.0" /></padding>
        <VBox spacing="10.0">
            <Label styleClass="ai-title" text="BIO-LINK TERMINAL" />
            <Separator maxWidth="50.0" style="-fx-opacity: 0.2;" />
        </VBox>
        <VBox spacing="25.0">
            <Button onAction="#goToMyProfile" styleClass="menu-link" text="PASSPORT" />
            <Button onAction="#toggleMenu" styleClass="menu-link" style="-fx-text-fill: #e63939;" text="LEGACY" />
            <Button styleClass="menu-link" text="SETTINGS" />
        </VBox>
        <Region VBox.vgrow="ALWAYS" />
        <Button styleClass="menu-link" style="-fx-font-size: 24px; -fx-opacity: 0.5;" text="LOGOUT / DISCONNECT" />
    </VBox>
</StackPane>