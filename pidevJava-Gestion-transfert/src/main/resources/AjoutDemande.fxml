<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.DemandeController"
            stylesheets="@style.css"
            prefHeight="600" prefWidth="900">

    <children>

        <VBox spacing="15" layoutX="20" layoutY="20" prefWidth="860">

            <!-- HEADER -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label text="Gestion des Demandes"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />

                <Pane HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnAdd"
                        text="+ Nouvelle Demande"
                        styleClass="btn-primary"/>
            </HBox>
            <TextField fx:id="searchField"
                       promptText="Rechercher..."
                       layoutX="20"
                       layoutY="10"
                       prefWidth="200"/>

            <!-- TABLE -->
            <TableView fx:id="tableDemande"
                       prefHeight="500"
                       styleClass="table-dark">

                <columns>

                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colBanque" text="Banque" prefWidth="100"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
                    <TableColumn fx:id="colQuantite" text="Quantité" prefWidth="100"/>
                    <TableColumn fx:id="colUrgence" text="Urgence" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="140"/>

                </columns>

            </TableView>
            <Button text="Transferts" onAction="#goToTransfert" styleClass="btn-primary"/>
            <Button text="Demandes" onAction="#goToDemande"/>
        </VBox>

    </children>

</AnchorPane>
