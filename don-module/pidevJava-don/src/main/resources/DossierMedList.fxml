<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="750.0" prefWidth="1250.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DossierMedListController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <!-- Subdued AI Blue & Red aesthetic glow -->
    <Circle radius="300.0" fill="#4a90e2" opacity="0.03" StackPane.alignment="BOTTOM_LEFT" />
    <Circle radius="200.0" fill="#e63939" opacity="0.04" StackPane.alignment="TOP_RIGHT" />

    <HBox spacing="0">
        <!-- Admin Navigation Sidebar -->
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar-glass">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0" />
            </padding>
            <VBox spacing="5.0">
                <Label styleClass="nav-logo-text" text="BLOODLINK" />
                <Label style="-fx-text-fill:#888888; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:0 0 0 6;" text="CLINICAL SYSTEM" />
            </VBox>
            <Region prefHeight="50.0" />
            <VBox spacing="8.0">
                <Button styleClass="menu-button" text="📊 Master Dashboard" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button styleClass="nav-link-active" style="-fx-padding:10 15; -fx-background-color:rgba(255,62,62,0.1); -fx-background-radius:8;" text="🩺 Medical Logs" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                <Button onAction="#goToDonationLogs" styleClass="menu-button" text="🩸 Live Inventory" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />

            <!-- Realtime Engine Check -->
            <VBox spacing="10" styleClass="ai-mini-card">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="15" />
                </padding>
                <Label styleClass="ai-label" text="AI STATUS" style="-fx-text-fill:gray; -fx-font-weight:900;" />
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Circle fill="#00ff88" radius="4" />
                    <Label style="-fx-text-fill:white; -fx-font-weight:bold;" text="Neural Link Active" />
                </HBox>
            </VBox>
        </VBox>

        <VBox spacing="25.0" styleClass="main-content" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="35.0" left="40.0" right="40.0" top="35.0" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label styleClass="hero-title" style="-fx-font-size:42px; -fx-text-alignment:left;" text="Patient Repository" />
                    <Label styleClass="hero-description-v2" text="Encrypted demographic parameters and AI eligibility predictions." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <TextField fx:id="searchField" prefWidth="300" promptText="Filter by patient name..." styleClass="dark-input" />
                    <Button onAction="#openAddMedicalView" styleClass="btn-prime-home" text="+ Open File" />
                </HBox>
            </HBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                <!-- Patient Table Area -->
                <VBox spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <TableView fx:id="mainTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="50" text="FILE ID" />
                            <TableColumn fx:id="colPrenom" prefWidth="120" text="FIRST NAME" />
                            <TableColumn fx:id="colNom" prefWidth="120" text="LAST NAME" />
                            <TableColumn fx:id="colAge" prefWidth="60" text="AGE" />
                            <TableColumn fx:id="colSexe" prefWidth="80" text="GENDER" />
                            <TableColumn fx:id="colBlood" prefWidth="80" text="BLOOD" />
                            <TableColumn fx:id="colTaille" prefWidth="90" text="HEIGHT(cm)" />
                            <TableColumn fx:id="colTemp" prefWidth="90" text="TEMP(°C)" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT">
                        <!-- THE ARROW THAT CRASHED JAVA HAS BEEN REMOVED HERE -->
                        <Button onAction="#openManageMedicalView" styleClass="btn-secondary-home" text="Edit Selected Profile" />
                    </HBox>
                </VBox>

                <!-- Dedicated Clinical AI Pane -->
                <VBox minWidth="380.0" prefWidth="380.0" spacing="25.0">
                    <VBox spacing="20" styleClass="ai-predictor-card">
                        <padding>
                            <Insets bottom="30" left="25" right="25" top="30" />
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 24px;" text="🧠" />
                            <VBox>
                                <Label styleClass="ai-title" style="-fx-font-size:18px;" text="AI Hematology Scan" />
                                <Label style="-fx-text-fill:#bbbbbb;" text="Gemini Pro Vision Engine" />
                            </VBox>
                        </HBox>
                        <Separator style="-fx-opacity: 0.2;" />
                        <Label fx:id="aiResultLabel" styleClass="hero-description-v2" style="-fx-text-fill:white; -fx-line-spacing: 5;" text="Please select a genetic profile from the index to run eligibility diagnostics." wrapText="true" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button maxWidth="Infinity" onAction="#runAIPrediction" styleClass="btn-participate-full" text="Initialize Analysis Sequence" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</StackPane>