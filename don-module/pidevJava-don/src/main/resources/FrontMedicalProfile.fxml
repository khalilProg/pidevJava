<?xml version="1.0" encoding="UTF-8"?>

<!-- CRITICAL IMPORTS FOR IMAGES AND CHARTS -->
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.effect.DropShadow?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1400.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.FrontMedicalController">
    <stylesheets><URL value="@style.css" /></stylesheets>

    <VBox spacing="0">
        <!-- NAVIGATION BAR -->
        <HBox alignment="CENTER" minHeight="90.0" styleClass="navbar-top">
            <HBox spacing="10.0" styleClass="brand-section">
                <Circle fill="#e63939" radius="8.0" />
                <Label styleClass="brand-text" text="BLOODLINK" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="30.0">
                <Label styleClass="nav-link-active" text="Health Passport" />
                <Button onAction="#goToMyDonations" styleClass="nav-link" text="Donation Legacy" />
                <HBox alignment="CENTER" styleClass="user-pill"><Label styleClass="user-name-label" text="Verified Patient" /></HBox>
            </HBox>
            <padding><Insets left="50.0" right="50.0" /></padding>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox spacing="30.0">
                <padding><Insets bottom="40.0" left="50.0" right="50.0" top="40.0" /></padding>

                <!-- TOP ROW: DATA + QUICKCHART GAUGE -->
                <HBox spacing="30.0">
                    <!-- PERSONAL METRICS CARD -->
                    <VBox maxWidth="650.0" spacing="25.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="45.0" left="50.0" right="50.0" top="45.0" /></padding>
                        <Label styleClass="ai-title" text="CLINICAL BIOMETRICS" />
                        <GridPane hgap="25.0" vgap="25.0">
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="form-label" text="IDENTITY" /><Label fx:id="nameLabel" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: 800;" text="---" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="form-label" text="BLOOD GROUP" /><Label fx:id="bloodLabel" style="-fx-text-fill: #e63939; -fx-font-size: 24; -fx-font-weight: 900;" text="--" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="form-label" text="STATURE" /><Label fx:id="heightLabel" style="-fx-text-fill: white; -fx-font-size: 16;" text="0 cm" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="form-label" text="BODY MASS" /><Label fx:id="weightLabel" style="-fx-text-fill: white; -fx-font-size: 16;" text="0 kg" />
                            </VBox>
                        </GridPane>
                        <HBox spacing="20">
                            <VBox><Label styleClass="form-label" text="AGE"/><Label fx:id="ageLabel" style="-fx-text-fill:white;" text="--"/></VBox>
                            <VBox><Label styleClass="form-label" text="GENDER"/><Label fx:id="genderLabel" style="-fx-text-fill:white;" text="--"/></VBox>
                        </HBox>
                    </VBox>

                    <!-- QUICKCHART RADIANT GAUGE -->
                    <VBox alignment="CENTER" minWidth="500.0" spacing="20.0" styleClass="ai-predictor-card">
                        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                        <Label styleClass="ai-title" text="VITASPHERE STABILITY GAUGE" />
                        <StackPane>
                            <!-- The Gauge rendered by QuickChart -->
                            <ImageView fx:id="bmiQuickChartImage" fitHeight="280.0" fitWidth="280.0" pickOnBounds="true" preserveRatio="true">
                                <effect>
                                    <DropShadow color="#e63939" radius="15" spread="0.1" />
                                </effect>
                            </ImageView>
                            <VBox alignment="CENTER" translateY="35">
                                <Label fx:id="bmiValueLabel" style="-fx-text-fill: white; -fx-font-size: 45; -fx-font-weight: 900;" text="0.0" />
                                <Label fx:id="bmiStatusLabel" style="-fx-text-fill: #888; -fx-font-size: 11; -fx-font-weight: bold;" text="WAITING FOR DATA..." />
                            </VBox>
                        </StackPane>
                        <Label fx:id="recoveryLabel" style="-fx-text-fill: #ccc; -fx-font-size: 12; -fx-text-alignment: center;" text="..." wrapText="true" />
                    </VBox>
                </HBox>

                <!-- CHART SECTION -->
                <VBox spacing="20.0" styleClass="glass-card">
                    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                    <Label styleClass="form-label" text="HISTORICAL VARIATION" />
                    <LineChart fx:id="biometricChart" createSymbols="true" horizontalGridLinesVisible="false" legendVisible="false" prefHeight="300.0" verticalGridLinesVisible="false">
                        <xAxis><CategoryAxis side="BOTTOM" fx:id="xAxis" tickLabelFill="GRAY" /></xAxis>
                        <yAxis><NumberAxis forceZeroInRange="false" side="LEFT" fx:id="yAxis" tickLabelFill="GRAY" /></yAxis>
                    </LineChart>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>