<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefWidth="550.0" prefHeight="650.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DonationAddController">
    <stylesheets><URL value="@style.css" /></stylesheets>

    <VBox alignment="CENTER">
        <VBox styleClass="form-card" maxWidth="450" spacing="25">
            <padding><Insets bottom="40" left="40" right="40" top="40" /></padding>
            <VBox alignment="CENTER" spacing="5">
                <Label styleClass="stat-card-title" style="-fx-font-size:28px;" text="New Donation" />
                <Label styleClass="stat-card-subtitle" text="Registering new bio-intake form." />
            </VBox>

            <VBox spacing="18">
                <VBox spacing="6">
                    <Label styleClass="form-label" text="SELECT DONOR" />
                    <ComboBox fx:id="clientBox" promptText="Choose existing patient..." styleClass="combo-box" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="6">
                    <Label styleClass="form-label" text="PARTNER FACILITY" />
                    <ComboBox fx:id="entiteBox" promptText="Select Collection Center..." styleClass="combo-box" maxWidth="Infinity" />
                </VBox>

                <HBox spacing="15">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="CATEGORY" />
                        <ComboBox fx:id="typeFieldBox" promptText="Full/Plasma" styleClass="combo-box" maxWidth="Infinity" />
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="VOLUME EXTRACT (ml)" />
                        <TextField fx:id="qteField" promptText="450.0" styleClass="dark-input" />
                    </VBox>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="15">
                <Button onAction="#closeWindow" styleClass="btn-outline-red" text="Discard" alignment="CENTER" minWidth="100"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleAddDonation" styleClass="btn-primary-modern" text="Submit Profile To Chain" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>