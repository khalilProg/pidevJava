<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" prefHeight="750.0" prefWidth="1250.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.DonationListController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <!-- Aesthetic Ambient Background Glows -->
    <Circle radius="350.0" fill="#e63939" opacity="0.05" StackPane.alignment="TOP_RIGHT" translateY="-50" translateX="50"/>
    <Circle radius="200.0" fill="#c62828" opacity="0.03" StackPane.alignment="BOTTOM_LEFT" />

    <HBox spacing="0">
        <!-- Sleek Admin Sidebar -->
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar-glass">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0" />
            </padding>
            <VBox spacing="5.0">
                <Label styleClass="nav-logo-text" text="BLOODLINK" />
                <Label style="-fx-text-fill:#888888; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:0 0 0 6;" text="INTELLIGENT ADMIN" />
            </VBox>
            <Region prefHeight="50.0" />
            <VBox spacing="8.0">
                <Button styleClass="menu-button" text="📊 Master Dashboard" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button onAction="#goToMedicalFolders" styleClass="menu-button" text="🩺 Medical Logs" maxWidth="Infinity" alignment="CENTER_LEFT" />
                <Button styleClass="nav-link-active" style="-fx-padding:10 15; -fx-background-color:rgba(255,62,62,0.1); -fx-background-radius:8;" text="🩸 Live Inventory" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <!-- Neural Network Tracker Status -->
            <VBox styleClass="ai-predictor-card" spacing="10">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="15" />
                </padding>
                <Label styleClass="ai-title" text="AI Supply Guard" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="4" styleClass="live-dot-v2" fill="#ff3e3e" />
                    <Label styleClass="ai-text" style="-fx-text-fill:white;" text="Monitoring stock dynamically." wrapText="true"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Main Workspace -->
        <VBox styleClass="main-content" HBox.hgrow="ALWAYS" spacing="25.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label styleClass="hero-title" style="-fx-font-size:42px; -fx-text-alignment:left;" text="Donation Logs" />
                    <Label styleClass="hero-description-v2" text="Global volume pipeline overview and management." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="20">
                    <TextField fx:id="searchField" prefWidth="320" promptText="Search entity or types..." styleClass="dark-input" />
                    <Button onAction="#openAddDonationView" styleClass="btn-prime-home" text="+ Log Intake" />
                </HBox>
            </HBox>

            <VBox styleClass="glass-card" VBox.vgrow="ALWAYS" spacing="15.0">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <TableView fx:id="donationTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50" text="LOG ID" />
                        <TableColumn fx:id="colClientId" prefWidth="150" text="PATIENT ID" />
                        <TableColumn fx:id="colEntityId" prefWidth="150" text="CENTER / ORG" />
                        <TableColumn fx:id="colType" prefWidth="150" text="CLASSIFICATION" />
                        <TableColumn fx:id="colQte" prefWidth="150" text="YIELD (mL)" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <!-- THE FIX IS RIGHT HERE: Removed the invalid arrow -> -->
                    <Label styleClass="hero-description-v2" text="Select a log in table to edit: " />
                    <Button onAction="#openManageDonationView" styleClass="btn-secondary-home" text="Edit / Review Details" />
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>